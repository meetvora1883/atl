<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: title || 'Error' }) %>
</head>
<body>
  <%- include('partials/loading-screen') %>
  <div class="app-shell">
    <div class="main-wrap">
      <%- include('partials/topbar') %>
      <div class="error-page">
        <div style="text-align:center; position:relative; z-index:1;">
          <h1 style="font-size:4rem; margin:0;">⚠️</h1>
          <h2 style="margin:16px 0 8px;"><%= title || 'Error' %></h2>
          <p class="text-muted"><%= message || 'Something went wrong.' %></p>
          <a href="/" class="btn btn-primary mt-24"><i class="bi bi-arrow-left"></i> Back to home</a>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/scripts') %>
</body>
</html>
