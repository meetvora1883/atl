<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Welcome' }) %>
</head>
<body>
  <%- include('partials/loading-screen') %>
  <div class="page">
    <nav class="splash-nav">
      <div class="brand"><span class="dot"></span> HyperCity</div>
      <a href="<%= domain %>/auth/discord" class="btn btn-primary btn-sm">Login</a>
    </nav>

    <div class="splash-hero">
      <div class="splash-eyebrow">Guild dashboard &amp; control room</div>
      <h1>Run your Discord server<br />like a premium SaaS application.</h1>
      <p>Analytics, moderation, events, bot management — all in one glassmorphic control panel. Designed for Discord admins and bot developers.</p>

      <% if (loginFailed) { %>
        <div style="margin-bottom: 20px; padding: 12px 16px; background: rgba(255,107,107,0.15); border: 1px solid rgba(255,107,107,0.3); border-radius: 10px; color: #ff9a9a; font-size: 0.88rem;">
          <i class="bi bi-exclamation-circle" style="margin-right: 8px;"></i>Login failed — try again or contact support.
        </div>
      <% } %>
      <% if (sessionExpired) { %>
        <div style="margin-bottom: 20px; padding: 12px 16px; background: rgba(79,209,255,0.15); border: 1px solid rgba(79,209,255,0.3); border-radius: 10px; color: #7ac9ff; font-size: 0.88rem;">
          <i class="bi bi-info-circle" style="margin-right: 8px;"></i>Your session expired. Please log in again.
        </div>
      <% } %>

      <form id="login-form" action="<%= domain %>/auth/discord" method="GET" style="display: flex; flex-direction: column; gap: 14px; align-items: center;">
        <button type="submit" class="btn btn-primary" style="width: 100%; max-width: 280px;">
          <i class="bi bi-discord"></i> Login with Discord
        </button>
        <label class="remember-row">
          <input type="checkbox" name="remember" value="1" />
          <span>Keep me logged in for 90 days</span>
        </label>
      </form>

      <svg class="skyline" viewBox="0 0 1200 220" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="bldg" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#161d38" />
            <stop offset="100%" stop-color="#0d1226" />
          </linearGradient>
        </defs>
        <g fill="url(#bldg)">
          <rect x="0" y="90" width="70" height="130" />
          <rect x="80" y="50" width="55" height="170" />
          <rect x="145" y="110" width="60" height="110" />
          <rect x="215" y="30" width="75" height="190" />
          <rect x="300" y="70" width="50" height="150" />
          <rect x="360" y="20" width="90" height="200" />
          <rect x="460" y="95" width="65" height="125" />
          <rect x="535" y="55" width="55" height="165" />
          <rect x="600" y="10" width="100" height="210" />
          <rect x="710" y="80" width="60" height="140" />
          <rect x="780" y="45" width="70" height="175" />
          <rect x="860" y="100" width="55" height="120" />
          <rect x="925" y="25" width="85" height="195" />
          <rect x="1020" y="65" width="60" height="155" />
          <rect x="1090" y="95" width="70" height="125" />
        </g>
        <g fill="var(--accent-amber)">
          <% for (let i = 0; i < 60; i++) { %>
            <rect class="window" x="<%= 10 + (i * 19) % 1180 %>" y="<%= 40 + ((i * 37) % 150) %>" width="6" height="8" />
          <% } %>
        </g>
      </svg>
    </div>
  </div>
  <%- include('partials/scripts') %>
</body>
</html>
