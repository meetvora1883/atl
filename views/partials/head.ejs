<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title><%= typeof title !== 'undefined' ? title + ' · HyperCity' : 'HyperCity Dashboard' %></title>

<!-- CSRF token – available globally -->
<script>
  window.__CSRF_TOKEN__ = window.__CSRF_TOKEN__ || "<%= csrfToken %>";
  console.log('[Head] CSRF Token set:', window.__CSRF_TOKEN__);
</script>

<script src="/js/deterrents.js" defer></script>

<!-- PWA Manifest & Icons -->
<link rel="manifest" href="/manifest.json" />
<meta name="theme-color" content="#0a0716" />
<link rel="icon" href="/icons/icon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/icons/icon.svg" />

<!-- Additional PWA Meta Tags -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />

<!-- Global settings -->
<meta name="hc-date-format" content="<%= globalSettings?.dateFormat || 'MM/DD/YYYY' %>" />
<meta name="hc-language" content="<%= userLanguage || 'en' %>" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<link rel="stylesheet" href="/css/style.css" />

<!-- Page-specific styles -->
<% if (typeof pageStyles !== 'undefined' && pageStyles) { %>
  <link rel="stylesheet" href="<%= pageStyles %>" />
<% } %>