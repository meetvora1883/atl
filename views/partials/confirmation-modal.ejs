<!-- Confirmation Modal – reusable across the app -->
<div class="modal-overlay" id="confirmationModal" style="display: none;">
  <div class="modal-box" style="max-width: 420px; padding: 0;">
    <div class="modal-header" style="background: var(--bg-2); border-bottom: 1px solid var(--glass-border);">
      <div class="left"><h3 id="confirmModalTitle" style="color: var(--text-primary); font-size: 1.1rem;">Confirm</h3></div>
      <button class="close-btn" id="confirmModalClose">&times;</button>
    </div>
    <div class="modal-body" style="padding: 20px 24px;">
      <p id="confirmModalMessage" style="margin: 0 0 16px 0; color: var(--text-primary);"></p>
      <div style="display: flex; justify-content: flex-end; gap: 12px;">
        <button class="btn btn-ghost" id="confirmModalCancel">Cancel</button>
        <button class="btn btn-danger" id="confirmModalConfirm">Confirm</button>
      </div>
    </div>
  </div>
</div>