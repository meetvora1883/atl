<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Flag Call System' }) %>
  <style>
    /* ----- Global overrides ----- */
    .btn {
      min-height: 48px;
      max-height: 56px;
      height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-sizing: border-box;
      transition: all 0.15s ease;
      padding: 0 18px;
      font-weight: 600;
    }
    .btn .spinner {
      display: none;
      flex: 0 0 16px;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    .btn.loading .spinner { display: inline-block; }
    .btn .btn-text {
      display: inline-block;
      white-space: nowrap;
      flex: 0 1 auto;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .flag-stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 16px;
      margin-bottom: 20px;
    }
    .flag-stat-card {
      text-align: center;
      padding: 16px 12px;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      backdrop-filter: blur(16px);
    }
    .flag-stat-card .emoji { font-size: 1.8rem; }
    .flag-stat-card .count { font-size: 2rem; font-weight: 700; font-family: var(--font-mono); }
    .flag-stat-card .label { font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; }

    .admin-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-top: 12px;
    }
    .admin-grid .btn {
      width: 100%;
      min-height: 48px;
      max-height: 56px;
      height: 48px;
    }
    .admin-grid .btn:last-child { grid-column: 1 / -1; }

    .channel-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 8px;
    }
    .channel-row .channel-select-wrap {
      flex: 1;
      min-width: 180px;
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      padding: 0 12px;
    }
    .channel-row .channel-select-wrap i {
      color: var(--text-muted);
      font-size: 1.1rem;
    }
    .channel-row .channel-select-wrap select {
      flex: 1;
      padding: 10px 0;
      background: transparent;
      border: none;
      color: var(--text-primary);
      font-family: var(--font-body);
      outline: none;
    }

    .activity-feed { max-height: 200px; overflow-y: auto; font-size: 0.9rem; }
    .activity-item {
      padding: 6px 0;
      border-bottom: 1px solid var(--glass-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .activity-item .time { color: var(--text-muted); font-size: 0.75rem; }

    .results-group { margin-bottom: 16px; }
    .results-group .header {
      display: flex;
      justify-content: space-between;
      font-weight: 600;
      font-size: 0.95rem;
      margin-bottom: 6px;
    }
    .player-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 4px 0;
      font-size: 0.85rem;
    }
    .player-item img { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; }

    .search-result {
      padding: 6px 10px;
      cursor: pointer;
      border-radius: 6px;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: background 0.15s;
    }
    .search-result:hover { background: var(--glass-strong); }
    .search-result img { width: 32px; height: 32px; border-radius: 50%; }
    .search-result .info { flex: 1; display: flex; flex-direction: column; }
    .search-result .info .name { font-weight: 600; }
    .search-result .info .sub { font-size: 0.8rem; color: var(--text-muted); }

    /* ----- Modals with sticky footer ----- */
    .modal-overlay {
      position: fixed;
      inset: 0;
      overflow-y: auto;
      padding: 24px;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      display: none;
      align-items: flex-start;
      justify-content: center;
      z-index: 9999;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      width: 95%;
      max-width: 820px;
      background: var(--bg-2);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      overflow: hidden;
      margin: auto;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      transform: translateY(20px);
      transition: transform 0.22s ease-out, opacity 0.22s ease-out;
      opacity: 0;
      box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    }
    .modal-overlay.open .modal-box {
      transform: translateY(0);
      opacity: 1;
    }
    .modal-header {
      padding: 16px 24px;
      border-bottom: 1px solid var(--glass-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-shrink: 0;
      background: var(--bg-2);
      z-index: 10;
    }
    .modal-header h3 { margin: 0; font-size: 1.15rem; }
    .modal-header .close-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 1.5rem;
      cursor: pointer;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s;
    }
    .modal-header .close-btn:hover { background: rgba(255,255,255,0.08); color: var(--danger); }
    .modal-body {
      padding: 24px;
      overflow-y: auto;
      flex: 1;
    }
    .modal-footer {
      padding: 16px 24px;
      border-top: 1px solid var(--glass-border);
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      flex-shrink: 0;
      background: var(--bg-2);
      z-index: 10;
    }

    /* ----- Message Status Card (new) ----- */
    .status-card {
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      padding: 20px 24px;
      backdrop-filter: blur(16px);
      margin-bottom: 20px;
      display: flex;
      flex-wrap: wrap;
      align-items: flex-start;
      gap: 16px 24px;
    }
    .status-card .status-icon {
      font-size: 2rem;
      line-height: 1;
      flex-shrink: 0;
      margin-top: 4px;
    }
    .status-card .status-main { flex: 1; min-width: 200px; }
    .status-card .status-main .title {
      font-weight: 700;
      font-size: 1.1rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .status-card .status-main .title .badge {
      font-size: 0.7rem;
      padding: 2px 12px;
      border-radius: 999px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .status-card .status-main .sub { color: var(--text-muted); font-size: 0.9rem; margin-top: 2px; }
    .status-card .status-details {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 24px;
      font-size: 0.85rem;
      margin-top: 6px;
    }
    .status-card .status-details .label { color: var(--text-muted); }
    .status-card .status-details .value { font-family: var(--font-mono); }
    .status-card .status-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 6px;
    }
    .status-card .status-actions .btn { height: 36px; min-height: 36px; font-size: 0.8rem; padding: 0 14px; }

    /* Active / Deleted / No Message states */
    .status-card.active .status-icon { color: #22c55e; }
    .status-card.active .badge { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid #22c55e; }
    .status-card.deleted .status-icon { color: #ef4444; }
    .status-card.deleted .badge { background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid #ef4444; }
    .status-card.none .status-icon { color: #f59e0b; }
    .status-card.none .badge { background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid #f59e0b; }

    /* ----- Send Discord Modal: two columns ----- */
    .send-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .send-grid .send-left { display: flex; flex-direction: column; gap: 16px; }
    .send-grid .send-right { display: flex; flex-direction: column; gap: 12px; }

    .send-field label {
      display: block;
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 4px;
      font-weight: 500;
    }
    .send-field input, .send-field textarea, .send-field select {
      width: 100%;
      padding: 8px 12px;
      border-radius: 10px;
      border: 1px solid var(--glass-border);
      background: var(--glass);
      color: var(--text-primary);
      font-family: var(--font-body);
      font-size: 0.9rem;
    }
    .send-field textarea { resize: vertical; min-height: 60px; }
    .send-field input:focus, .send-field textarea:focus { outline: none; border-color: var(--accent-cyan); }

    .embed-preview {
      background: var(--bg-1);
      border-radius: 12px;
      padding: 16px;
      border: 1px solid var(--glass-border);
    }
    .embed-preview .preview-title {
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--accent-cyan);
    }
    .embed-preview .preview-desc {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin: 4px 0 8px;
    }
    .embed-preview .preview-fields {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px 12px;
      font-size: 0.85rem;
    }
    .embed-preview .preview-fields span { color: var(--text-primary); }
    .embed-preview .preview-footer {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 6px;
      font-style: italic;
    }
    .embed-preview .preview-color-dot {
      display: inline-block;
      width: 20px;
      height: 20px;
      border-radius: 4px;
      vertical-align: middle;
    }

    .button-preview {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }
    .button-preview .btn-preview {
      padding: 4px 12px;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 600;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      color: var(--text-primary);
    }
    .button-preview .btn-preview.primary { background: #5865f2; border-color: #5865f2; color: #fff; }
    .button-preview .btn-preview.success { background: #57e39a; border-color: #57e39a; color: #000; }
    .button-preview .btn-preview.secondary { background: #4a4d5e; border-color: #4a4d5e; color: #fff; }
    .button-preview .btn-preview.danger { background: #ef4444; border-color: #ef4444; color: #fff; }

    /* ----- Custom Color Picker ----- */
    .color-picker-wrap {
      position: relative;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .color-picker-wrap .color-swatch {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      border: 2px solid var(--glass-border);
      cursor: pointer;
      flex-shrink: 0;
      transition: border-color 0.15s;
    }
    .color-picker-wrap .color-swatch:hover { border-color: var(--accent-cyan); }
    .color-picker-wrap .color-hex {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      background: var(--glass);
      padding: 4px 10px;
      border-radius: 6px;
      border: 1px solid var(--glass-border);
      color: var(--text-primary);
      width: 80px;
    }
    .color-picker-popup {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      background: var(--bg-2);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      padding: 12px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.6);
      z-index: 50;
      display: none;
      width: 220px;
    }
    .color-picker-popup.open { display: block; }
    .color-picker-popup .preset-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 6px;
      margin-bottom: 8px;
    }
    .color-picker-popup .preset-grid .preset {
      width: 100%;
      aspect-ratio: 1;
      border-radius: 6px;
      border: 2px solid transparent;
      cursor: pointer;
      transition: border-color 0.15s;
    }
    .color-picker-popup .preset-grid .preset:hover { border-color: var(--accent-cyan); }
    .color-picker-popup .preset-grid .preset.active { border-color: #fff; }
    .color-picker-popup .custom-input {
      display: flex;
      gap: 6px;
      align-items: center;
    }
    .color-picker-popup .custom-input input {
      flex: 1;
      padding: 4px 8px;
      border-radius: 6px;
      border: 1px solid var(--glass-border);
      background: var(--glass);
      color: var(--text-primary);
      font-family: var(--font-mono);
      font-size: 0.8rem;
    }

    .mode-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .mode-card {
      padding: 10px 14px;
      border: 2px solid var(--glass-border);
      border-radius: 10px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      background: var(--glass);
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .mode-card:hover { border-color: var(--accent-cyan); }
    .mode-card.selected { border-color: var(--accent-cyan); background: rgba(79,209,255,0.08); }
    .mode-card .mode-title { font-weight: 600; display: flex; align-items: center; gap: 6px; font-size: 0.9rem; }
    .mode-card .mode-desc { font-size: 0.75rem; color: var(--text-muted); }
    .mode-card .mode-radio { display: none; }
    .mode-card.selected .mode-radio { display: inline; }

    .badge-status {
      display: inline-block;
      padding: 2px 12px;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 600;
    }
    .badge-status.existing { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid #22c55e; }
    .badge-status.deleted { background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid #ef4444; }
    .badge-status.none { background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid #f59e0b; }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.85rem;
    }
    .status-badge.open { background: rgba(46,204,113,0.15); color: var(--accent-green); }
    .status-badge.locked { background: rgba(231,76,60,0.15); color: var(--danger); }
    .status-badge .dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }

    .error-banner {
      background: rgba(255,107,107,0.15);
      border: 1px solid var(--danger);
      border-radius: 10px;
      padding: 12px 16px;
      color: var(--danger);
      margin-bottom: 16px;
      display: none;
    }
    .error-banner .retry-btn { margin-left: 12px; }
    .debug-info {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-muted);
      background: var(--bg-1);
      padding: 8px 12px;
      border-radius: 6px;
      margin-top: 4px;
      white-space: pre-wrap;
      word-break: break-all;
    }

    .btn-large {
      padding: 10px 28px;
      font-size: 1rem;
      min-width: 130px;
    }

    @media (max-width: 768px) {
      .send-grid { grid-template-columns: 1fr; }
      .mode-cards { grid-template-columns: 1fr; }
      .admin-grid { grid-template-columns: 1fr; }
      .admin-grid .btn:last-child { grid-column: 1; }
      .status-card { flex-direction: column; }
      .modal-box { max-width: 100%; }
    }
  </style>
</head>
<body>
  <%- include('partials/loading-screen') %>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'flag_calls' }) %>
    <div class="main-wrap">
      <%- include('partials/topbar') %>
      <main class="page-content">
        <div class="container">
          <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:20px;">
            <h1 style="margin:0;">🏳 Flag Call System</h1>
            <div id="statusBadge" class="status-badge open">
              <span class="dot"></span>
              <span id="statusText">Loading…</span>
            </div>
          </div>

          <!-- Error banner -->
          <div class="error-banner" id="errorBanner">
            <span id="errorMessage">Failed to load data.</span>
            <button class="btn btn-sm btn-danger retry-btn" id="retryBtn">🔄 Retry</button>
            <div class="debug-info" id="debugInfo" style="display:none;"></div>
          </div>

          <!-- Message Status Card (polished) -->
          <div class="status-card none" id="statusCard">
            <div class="status-icon" id="statusIcon">➕</div>
            <div class="status-main">
              <div class="title">
                <span id="statusTitle">No Message</span>
                <span class="badge" id="statusBadgeMsg">NO MESSAGE</span>
              </div>
              <div class="sub" id="statusSub">No Discord message has been created yet.</div>
              <div class="status-details">
                <span><span class="label">Message ID:</span> <span class="value" id="msgIdDisplay">—</span></span>
                <span><span class="label">Channel:</span> <span class="value" id="msgChannelDisplay">—</span></span>
                <span><span class="label">Last Updated:</span> <span class="value" id="msgUpdatedDisplay">—</span></span>
              </div>
            </div>
            <div class="status-actions" id="statusActions">
              <!-- dynamic buttons -->
            </div>
          </div>

          <!-- Stats -->
          <div class="flag-stats-grid">
            <div class="flag-stat-card">
              <div class="emoji">📡</div>
              <div class="count" id="statChannel" style="font-size:1rem;">—</div>
              <div class="label">Discord Channel</div>
            </div>
            <div class="flag-stat-card">
              <div class="emoji">🆔</div>
              <div class="count" id="statMessage" style="font-size:1rem;">—</div>
              <div class="label">Message ID</div>
            </div>
            <div class="flag-stat-card">
              <div class="emoji">🗳️</div>
              <div class="count" id="statTotal">0</div>
              <div class="label">Total Votes</div>
            </div>
            <div class="flag-stat-card">
              <div class="emoji">👥</div>
              <div class="count" id="statUnique">0</div>
              <div class="label">Unique Voters</div>
            </div>
          </div>

          <!-- Flag counts -->
          <div class="flag-stats-grid">
            <div class="flag-stat-card">
              <div class="emoji">🏳</div>
              <div class="count" id="count2">0</div>
              <div class="label">2 Flags</div>
            </div>
            <div class="flag-stat-card">
              <div class="emoji">🏳🏳🏳</div>
              <div class="count" id="count3">0</div>
              <div class="label">3 Flags</div>
            </div>
            <div class="flag-stat-card">
              <div class="emoji">🏳🏳🏳🏳</div>
              <div class="count" id="count4">0</div>
              <div class="label">4 Flags</div>
            </div>
            <div class="flag-stat-card">
              <div class="emoji">🏳🏳🏳🏳🏳</div>
              <div class="count" id="count5">0</div>
              <div class="label">5 Flags</div>
            </div>
          </div>

          <!-- Activity feed -->
          <div class="glass card">
            <h3 style="margin-top:0;">📋 Recent Activity</h3>
            <div class="activity-feed" id="activityFeed">
              <div class="text-muted">No activity yet.</div>
            </div>
          </div>

          <!-- Live results -->
          <div class="glass card">
            <h3 style="margin-top:0;">📊 Live Results</h3>
            <div id="resultsContainer">
              <div class="text-muted">Loading results…</div>
            </div>
          </div>

          <!-- Admin Controls -->
          <% if (user && user.permissions && user.permissions.includes('manage_flag_calls')) { %>
          <div class="glass card">
            <h3 style="margin-top:0;">⚙️ Admin Controls</h3>
            <div class="admin-grid">
              <button class="btn btn-primary" id="lockToggleBtn">
                <span class="spinner"></span>
                <span class="btn-text">🔒 Lock</span>
              </button>
              <button class="btn btn-danger" id="restartBtn">
                <span class="spinner"></span>
                <span class="btn-text">🔄 Restart</span>
              </button>
              <button class="btn btn-primary" id="resultBtn">
                <span class="spinner"></span>
                <span class="btn-text">📊 Results</span>
              </button>
              <button class="btn btn-primary" id="changeVoteBtn">
                <span class="spinner"></span>
                <span class="btn-text">✏️ Change Vote</span>
              </button>
              <button class="btn btn-primary" id="sendDiscordBtn">
                <span class="spinner"></span>
                <span class="btn-text">📤 Send Discord</span>
              </button>
              <button class="btn btn-primary" id="settingsBtn">
                <span class="spinner"></span>
                <span class="btn-text">⚙️ Button Settings</span>
              </button>
            </div>
            <hr style="border-color:var(--glass-border); margin:16px 0;">
            <div style="display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-bottom:8px;">
              <h4 style="margin:0;">📡 Discord Channel</h4>
              <span id="channelStatus" class="badge" style="background:rgba(255,107,107,0.2);color:var(--danger); font-size:0.75rem; padding:2px 10px; border-radius:999px;">🔴 Not Connected</span>
              <span style="font-size:0.8rem; color:var(--text-muted);" id="channelNameDisplay">None selected</span>
            </div>
            <div class="channel-row">
              <div class="channel-select-wrap">
                <i class="bi bi-discord"></i>
                <select id="channelSelect"><option value="">Loading channels…</option></select>
              </div>
              <button class="btn btn-ghost btn-sm" id="refreshChannelsBtn">🔄 Refresh</button>
