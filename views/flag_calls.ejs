        document.getElementById('btnColor5').value = s.buttonColors ? s.buttonColors[5] || 4 : 4;
      } catch (e) { console.warn('Failed to load settings', e); }
    }

    // ---- Admin actions ----
    if (hasManage) {
      // Lock/Unlock
      document.getElementById('lockToggleBtn').addEventListener('click', async function() {
        if (actionRunning) return;
        actionRunning = true;
        var isLocked = this.querySelector('.btn-text').textContent.includes('Lock');
        var action = isLocked ? 'lock' : 'unlock';
        var label = isLocked ? 'Locking...' : 'Unlocking...';
        setButtonLoading(this, true, label);
        try {
          await apiFetch('/' + action, { method: 'POST' });
          await refreshAll();
          showToast('success', 'Success', isLocked ? 'Voting locked.' : 'Voting unlocked.');
        } catch (e) { showToast('error', 'Failed', e.message); }
        finally { setButtonLoading(this, false); actionRunning = false; }
      });

      // Restart
      document.getElementById('restartBtn').addEventListener('click', function() {
        if (actionRunning) return;
        var self = this;
        openConfirmModal({
          title: '🔄 Restart Flag Call',
          message: 'This will clear all votes and reset the session. The existing Discord message will be updated.',
          onConfirm: function() {
            actionRunning = true;
            setButtonLoading(self, true, 'Restarting...');
            apiFetch('/restart', { method: 'POST' })
              .then(async function() {
                await refreshAll();
                showToast('success', 'Restarted', 'Flag Call has been reset.');
              })
              .catch(function(e) { showToast('error', 'Failed', e.message); })
              .finally(function() { setButtonLoading(self, false); actionRunning = false; });
          }
        });
      });

      // Results
      document.getElementById('resultBtn').addEventListener('click', async function() {
        setButtonLoading(this, true, 'Loading...');
        try {
          var data = await apiFetch('/results');
          var body = document.getElementById('resultModalBody');
          var counts = [2,3,4,5];
          var html = '';
          for (var i=0; i<counts.length; i++) {
            var count = counts[i];
            var players = data.grouped[count] || [];
            var emoji = '🏳'.repeat(count);
            html += '<div class="results-group">';
            html += '<div class="header"><span>' + emoji + ' ' + count + ' Flags</span><span>' + players.length + '</span></div>';
            if (players.length === 0) html += '<div class="text-muted">None</div>';
            else {
              for (var j=0; j<players.length; j++) {
                var p = players[j];
                var avatar = p.avatar || 'https://cdn.discordapp.com/embed/avatars/0.png';
                html += '<div class="player-item">';
                html += '<img src="' + avatar + '" onerror="this.src=\'https://cdn.discordapp.com/embed/avatars/0.png\'" />';
                html += '<span>' + p.username + ' <span style="color:var(--text-muted);font-size:0.8rem;">&lt;@' + p.discordId + '&gt;</span></span>';
                html += '<span style="color:var(--text-muted);font-size:0.75rem;margin-left:auto;">' + new Date(p.submittedAt).toLocaleTimeString() + '</span>';
                html += '</div>';
              }
            }
            html += '</div>';
          }
          body.innerHTML = html;
          openModal('resultModal');
        } catch (e) { showToast('error', 'Failed', e.message); }
        finally { setButtonLoading(this, false); }
      });

      // Copy Results
      document.getElementById('copyResultBtn').addEventListener('click', function() {
        var body = document.getElementById('resultModalBody');
        var groups = body.querySelectorAll('.results-group');
        var text = '';
        groups.forEach(function(g) {
          var header = g.querySelector('.header');
          var items = g.querySelectorAll('.player-item');
          text += header.textContent.trim() + '\n';
          items.forEach(function(item) {
            var mention = item.querySelector('span').textContent.trim().split(' ').pop() || '';
            text += '• ' + mention + '\n';
          });
          text += '\n';
        });
        if (!text) { showToast('warning', 'Nothing to copy', 'No results available.'); return; }
        function copyFallback() {
          var textarea = document.createElement('textarea');
          textarea.value = text;
          textarea.style.position = 'fixed';
          textarea.style.left = '-9999px';
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();
          try { document.execCommand('copy'); showToast('success', 'Copied', 'Results copied.'); }
          catch (e) { showToast('error', 'Failed', 'Could not copy.'); }
          document.body.removeChild(textarea);
        }
        if (navigator.clipboard && window.isSecureContext) {
          navigator.clipboard.writeText(text).then(function() { showToast('success', 'Copied', 'Results copied.'); }).catch(copyFallback);
        } else { copyFallback(); }
      });

      // Change Vote
      document.getElementById('changeVoteBtn').addEventListener('click', function() {
        openModal('changeVoteModal');
        document.getElementById('changeSearch').value = '';
        document.getElementById('changeResults').innerHTML = '<div class="text-muted">Type to search players…</div>';
        document.getElementById('changeVoteForm').style.display = 'none';
        document.getElementById('saveVoteBtn').disabled = true;
        selectedChangePlayer = null;
      });

      var searchTimeout = null;
      document.getElementById('changeSearch').addEventListener('input', function() {
        clearTimeout(searchTimeout);
        var q = this.value.trim();
        if (q.length < 2) {
          document.getElementById('changeResults').innerHTML = '<div class="text-muted">Type at least 2 characters…</div>';
          return;
        }
        searchTimeout = setTimeout(function() {
          var container = document.getElementById('changeResults');
          apiFetch('/search?q=' + encodeURIComponent(q))
            .then(function(data) {
              if (!data.results || data.results.length === 0) { container.innerHTML = '<div class="text-muted">No players found.</div>'; return; }
              var html = '';
              data.results.forEach(function(p) {
                var avatar = p.avatar || 'https://cdn.discordapp.com/embed/avatars/0.png';
                html += '<div class="search-result" data-id="' + p.discord_id + '" data-flag="' + p.flag_count + '" data-name="' + p.username + '">';
                html += '<img src="' + avatar + '" onerror="this.src=\'https://cdn.discordapp.com/embed/avatars/0.png\'" />';
                html += '<div class="info"><span class="name">' + p.username + '</span><span class="sub">Current: ' + p.flag_count + ' Flags</span></div>';
                html += '</div>';
              });
              container.innerHTML = html;
              container.querySelectorAll('.search-result').forEach(function(el) {
                el.addEventListener('click', function() {
                  selectedChangePlayer = { id: this.dataset.id, name: this.dataset.name, flag: parseInt(this.dataset.flag, 10) };
                  document.getElementById('selectedPlayerName').value = selectedChangePlayer.name;
                  document.getElementById('currentVote').value = selectedChangePlayer.flag + ' Flags';
                  document.getElementById('newVoteSelect').value = selectedChangePlayer.flag;
                  document.getElementById('changeVoteForm').style.display = 'block';
                  document.getElementById('saveVoteBtn').disabled = false;
                });
              });
            })
            .catch(function(e) { container.innerHTML = '<div class="text-muted">Search failed.</div>'; });
        }, 300);
      });

      document.getElementById('saveVoteBtn').addEventListener('click', async function() {
        if (!selectedChangePlayer) return;
        if (actionRunning) return;
        actionRunning = true;
        setButtonLoading(this, true, 'Saving...');
        try {
          var newFlag = document.getElementById('newVoteSelect').value;
          await apiFetch('/change/' + selectedChangePlayer.id, {
            method: 'PUT',
            body: JSON.stringify({ flagCount: parseInt(newFlag, 10), username: selectedChangePlayer.name })
          });
          await refreshAll();
          showToast('success', 'Updated', 'Vote changed to ' + newFlag + ' Flags.');
          closeModal('changeVoteModal');
        } catch (e) { showToast('error', 'Failed', e.message); }
        finally { setButtonLoading(this, false); actionRunning = false; }
      });

      // Refresh channels
      document.getElementById('refreshChannelsBtn').addEventListener('click', function() { loadChannels(); });

      // Save Channel (only saves, no Discord send)
      document.getElementById('saveChannelBtn').addEventListener('click', async function() {
        if (actionRunning) return;
        var select = document.getElementById('channelSelect');
        var channelId = select.value;
        if (!channelId) { showToast('warning', 'Select a channel', 'Please select a channel first.'); return; }
        actionRunning = true;
        setButtonLoading(this, true, 'Saving...');
        try {
          var channelName = select.options[select.selectedIndex].text.replace('#', '');
          await apiFetch('/channel', { method: 'POST', body: JSON.stringify({ channelId: channelId, channelName: channelName }) });
          await refreshAll();
          showToast('success', 'Saved', 'Channel #' + channelName + ' saved.');
        } catch (e) { showToast('error', 'Failed', e.message); }
        finally { setButtonLoading(this, false); actionRunning = false; }
      });

      // Test message
      document.getElementById('testChannelBtn').addEventListener('click', async function() {
        if (actionRunning) return;
        actionRunning = true;
        setButtonLoading(this, true, 'Sending...');
        try {
          await apiFetch('/test', { method: 'POST' });
          await refreshAll();
          showToast('success', 'Test sent', 'Test message sent to Discord.');
        } catch (e) { showToast('error', 'Failed', e.message); }
        finally { setButtonLoading(this, false); actionRunning = false; }
      });

      // Send Discord modal
      document.getElementById('sendDiscordBtn').addEventListener('click', function() {
        if (actionRunning) return;
        populateChannelSelect(document.getElementById('sendChannelSelect'));
        if (document.getElementById('channelSelect').value) {
          document.getElementById('sendChannelSelect').value = document.getElementById('channelSelect').value;
        }
        document.getElementById('sendTitle').value = 'Flag Call Results';
        document.getElementById('sendDescription').value = 'Live voting results for the current flag call.';
        document.getElementById('sendFooter').value = 'Click a button below to vote';
        // Set color from settings
        var settingsColor = document.getElementById('settingsColorHex');
        if (settingsColor) {
          document.getElementById('colorHex').value = settingsColor.value;
          document.getElementById('colorSwatch').style.background = settingsColor.value;
        } else {
          document.getElementById('colorHex').value = '#2ecc71';
          document.getElementById('colorSwatch').style.background = '#2ecc71';
        }
        updateModeCards();
        var hint = document.getElementById('sendModeHint');
        if (currentMessageId && currentMessageExists) {
          hint.textContent = '🟢 Existing message found (ID: ' + currentMessageId + ')';
          hint.className = 'badge-status existing';
        } else if (currentMessageId && !currentMessageExists) {
          hint.textContent = '🔴 Message deleted. Will create new.';
          hint.className = 'badge-status deleted';
          document.querySelector('.mode-card[data-mode="create"]').click();
        } else {
          hint.textContent = '🟠 No existing message. Create new.';
          hint.className = 'badge-status none';
          document.querySelector('.mode-card[data-mode="create"]').click();
        }
        updatePreview();
        openModal('sendDiscordModal');
      });

      // Mode cards
      function updateModeCards() {
        var cards = document.querySelectorAll('.mode-card');
        var hasMsg = !!(currentMessageId && currentMessageExists);
        cards.forEach(function(card) {
          var mode = card.dataset.mode;
          if (mode === 'update' && !hasMsg) {
            card.style.opacity = '0.5';
            card.style.cursor = 'not-allowed';
            card.classList.remove('selected');
          } else {
            card.style.opacity = '1';
            card.style.cursor = 'pointer';
          }
          if (mode === 'create') card.classList.add('selected');
          else card.classList.remove('selected');
        });
        document.querySelector('.mode-card[data-mode="create"]').classList.add('selected');
        document.querySelector('.mode-card[data-mode="update"]').classList.remove('selected');
      }

      document.getElementById('modeCards').addEventListener('click', function(e) {
        var card = e.target.closest('.mode-card');
        if (!card) return;
        var mode = card.dataset.mode;
        if (mode === 'update' && !(currentMessageId && currentMessageExists)) {
          showToast('warning', 'Cannot update', 'No existing message to update.');
          return;
        }
        document.querySelectorAll('.mode-card').forEach(function(c) {
          c.classList.remove('selected');
          var radio = c.querySelector('.mode-radio');
          if (radio) radio.textContent = '○';
        });
        card.classList.add('selected');
        var radio = card.querySelector('.mode-radio');
        if (radio) radio.textContent = '◉';
      });

      // Live preview
      document.getElementById('sendTitle').addEventListener('input', updatePreview);
      document.getElementById('sendDescription').addEventListener('input', updatePreview);
      document.getElementById('sendFooter').addEventListener('input', updatePreview);
      document.getElementById('colorHex').addEventListener('input', updatePreview);

      // Send confirm
      document.getElementById('sendDiscordConfirmBtn').addEventListener('click', async function() {
        if (actionRunning) return;
        var channelSelect = document.getElementById('sendChannelSelect');
        var channelId = channelSelect.value;
        if (!channelId) { showToast('warning', 'Select a channel', 'Please select a Discord channel.'); return; }
        var title = document.getElementById('sendTitle').value.trim() || 'Flag Call Results';
        var description = document.getElementById('sendDescription').value.trim() || '';
        var footer = document.getElementById('sendFooter').value.trim() || '';
        var embedColor = document.getElementById('colorHex').value || '#2ecc71';
        var modeCard = document.querySelector('.mode-card.selected');
        var mode = modeCard ? modeCard.dataset.mode : 'create';

        if (mode === 'update' && !(currentMessageId && currentMessageExists)) mode = 'create';

        // Save channel if different
        var status = await apiFetch('/status');
        if (status.channelId !== channelId) {
          var channelName = channelSelect.options[channelSelect.selectedIndex].text.replace('#', '');
          await apiFetch('/channel', { method: 'POST', body: JSON.stringify({ channelId: channelId, channelName: channelName }) });
        }

        actionRunning = true;
        setButtonLoading(this, true, 'Sending...');
        try {
          await apiFetch('/send', {
            method: 'POST',
            body: JSON.stringify({ title: title, description: description, footer: footer, embedColor: embedColor, mode: mode })
          });
          await refreshAll();
          showToast('success', 'Sent', 'Discord message ' + (mode === 'update' ? 'updated' : 'created') + '.');
          closeModal('sendDiscordModal');
        } catch (e) { showToast('error', 'Failed', e.message); }
        finally { setButtonLoading(this, false); actionRunning = false; }
      });

      // Settings modal
      document.getElementById('settingsBtn').addEventListener('click', function() {
        loadSettings();
        openModal('settingsModal');
      });

      document.getElementById('saveSettingsBtn').addEventListener('click', async function() {
        setButtonLoading(this, true, 'Saving...');
        try {
          var payload = {
            embedColor: document.getElementById('settingsColorHex').value,
            buttonLabels: {
              2: document.getElementById('btnLabel2').value,
              3: document.getElementById('btnLabel3').value,
              4: document.getElementById('btnLabel4').value,
              5: document.getElementById('btnLabel5').value
            },
            buttonEmojis: {
              2: document.getElementById('btnEmoji2').value,
              3: document.getElementById('btnEmoji3').value,
              4: document.getElementById('btnEmoji4').value,
              5: document.getElementById('btnEmoji5').value
            },
            buttonColors: {
              2: parseInt(document.getElementById('btnColor2').value, 10),
              3: parseInt(document.getElementById('btnColor3').value, 10),
              4: parseInt(document.getElementById('btnColor4').value, 10),
              5: parseInt(document.getElementById('btnColor5').value, 10)
            }
          };
          await apiFetch('/settings', { method: 'PUT', body: JSON.stringify(payload) });
          showToast('success', 'Saved', 'Button settings updated.');
          closeModal('settingsModal');
          await refreshAll();
          // Update Discord message with new settings
          await apiFetch('/send', { method: 'POST', body: JSON.stringify({ mode: 'update' }) });
          showToast('success', 'Discord updated', 'Message updated with new button settings.');
        } catch (e) { showToast('error', 'Failed', e.message); }
        finally { setButtonLoading(this, false); }
      });

      // Initialize color pickers
      initColorPicker('colorSwatch', 'colorHex', 'colorPickerPopup', 'presetGrid', 'colorCustomHex', 'colorApplyBtn');
      initColorPicker('settingsColorSwatch', 'settingsColorHex', 'settingsColorPopup', 'settingsPresetGrid', 'settingsColorCustomHex', 'settingsColorApplyBtn');

      loadChannels();
    }

    // ---- Auto-refresh ----
    document.addEventListener('DOMContentLoaded', function() {
      refreshAll();
      loadSettings();
      autoRefreshInterval = setInterval(function() {
        if (!actionRunning) {
          refreshAll().catch(function(e) { console.warn('Auto-refresh failed:', e.message); });
        }
      }, 5000);
    });

    window.addEventListener('beforeunload', function() {
      if (autoRefreshInterval) clearInterval(autoRefreshInterval);
    });
  </script>
</body>
</html>