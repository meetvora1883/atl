  <%- include('partials/scripts') %>

  <script>
    // ---- Override date format ----
    if (typeof window.__refreshDates === 'function') {
      window.__refreshDates = function() {};
    }
    clearTimeout(window._dateFormatTimer);
    window._dateFormatTimer = 0;

    // ---- CSRF & API ----
    var csrfToken = window.__CSRF_TOKEN__ || '';
    var API_BASE = '/api/warboard/flags';

    // ---- Toast ----
    function showToast(type, title, message) {
      var container = document.getElementById('toast-container');
      if (!container) {
        container = document.createElement('div');
        container.id = 'toast-container';
        container.className = 'toast-container';
        container.style.position = 'fixed';
        container.style.bottom = '24px';
        container.style.right = '24px';
        container.style.display = 'flex';
        container.style.flexDirection = 'column';
        container.style.gap = '10px';
        container.style.zIndex = '999999';
        container.style.maxWidth = '340px';
        container.style.pointerEvents = 'none';
        document.body.appendChild(container);
      }
      var el = document.createElement('div');
      el.className = 'toast toast-' + type;
      el.style.pointerEvents = 'auto';
      el.style.background = 'rgba(15,12,28,0.97)';
      el.style.border = '1px solid var(--glass-border)';
      el.style.borderRadius = '12px';
      el.style.padding = '14px 16px';
      el.style.display = 'flex';
      el.style.alignItems = 'flex-start';
      el.style.gap = '10px';
      el.style.transform = 'translateX(120%)';
      el.style.opacity = '0';
      el.style.transition = 'transform 0.3s ease, opacity 0.3s ease';
      var icons = { success: 'bi-check-circle', warning: 'bi-exclamation-triangle', error: 'bi-x-circle', info: 'bi-info-circle' };
      el.innerHTML = '<i class="bi ' + (icons[type] || icons.info) + '" style="font-size:1.1rem;margin-top:2px;"></i>' +
        '<div style="flex:1;"><div style="font-weight:600;font-size:0.88rem;">' + title + '</div>' +
        (message ? '<div style="font-size:0.8rem;color:var(--text-muted);margin-top:2px;">' + message + '</div>' : '') +
        '</div>' +
        '<button class="toast-close" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1.2rem;">&times;</button>';
      container.appendChild(el);
      requestAnimationFrame(function() {
        el.style.transform = 'translateX(0)';
        el.style.opacity = '1';
      });
      var remove = function() {
        el.style.transform = 'translateX(120%)';
        el.style.opacity = '0';
        setTimeout(function() { if (el.parentNode) el.remove(); }, 300);
      };
      el.querySelector('.toast-close').addEventListener('click', remove);
      setTimeout(remove, 5000);
    }

    // ---- API fetch ----
    async function apiFetch(path, options) {
      options = options || {};
      var url = API_BASE + path;
      try {
        var res = await fetch(url, {
          method: options.method || 'GET',
          headers: {
            'Content-Type': 'application/json',
            'x-csrf-token': csrfToken,
            ...(options.headers || {})
          },
          credentials: 'include',
          body: options.body || undefined
        });
        var text = await res.text();
        var data;
        try { data = JSON.parse(text); } catch (e) { throw new Error('Server returned invalid JSON. Status: ' + res.status); }
        if (!res.ok || (data && data.ok === false)) throw new Error(data.error || 'HTTP ' + res.status);
        return data;
      } catch (err) {
        console.error('API error:', err.message);
        throw err;
      }
    }

    // ---- State ----
    var currentUser = <%- JSON.stringify(user) %>;
    var hasManage = currentUser && currentUser.permissions && currentUser.permissions.includes('manage_flag_calls');
    var selectedChangePlayer = null;
    var autoRefreshInterval = null;
    var firstLoad = true;
    var actionRunning = false;
    var currentMessageId = null;
    var currentMessageExists = false;
    var currentCounts = { 2:0, 3:0, 4:0, 5:0 };
    var currentTotal = 0;
    var discordChannels = [];
    var isChannelsLoaded = false;

    // ---- Helper: set button loading ----
    function setButtonLoading(btn, loading, text) {
      if (loading) {
        btn.classList.add('loading');
        btn.disabled = true;
        var ts = btn.querySelector('.btn-text');
        if (ts) ts.textContent = text || 'Loading...';
      } else {
        btn.classList.remove('loading');
        btn.disabled = false;
        var orig = btn.dataset.originalText;
        if (orig) {
          var ts = btn.querySelector('.btn-text');
          if (ts) ts.textContent = orig;
        }
      }
    }
    document.querySelectorAll('.admin-grid .btn').forEach(function(b) {
      var ts = b.querySelector('.btn-text');
      if (ts) b.dataset.originalText = ts.textContent.trim();
    });

    // ---- Modal helpers ----
    function openModal(id) { document.body.style.overflow = 'hidden'; document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.body.style.overflow = ''; document.getElementById(id).classList.remove('open'); }
    document.querySelectorAll('[data-close]').forEach(function(el) {
      el.addEventListener('click', function() { closeModal(this.dataset.close); });
    });
    document.querySelectorAll('.modal-overlay').forEach(function(el) {
      el.addEventListener('click', function(e) { if (e.target === this) closeModal(this.id); });
    });

    // ---- Confirm modal ----
    function openConfirmModal(opts) {
      var modal = document.getElementById('confirmModal');
      document.getElementById('confirmTitle').textContent = opts.title || 'Confirm';
      document.getElementById('confirmMessage').textContent = opts.message || 'Are you sure?';
      document.getElementById('confirmOk').onclick = function() {
        closeModal('confirmModal');
        if (opts.onConfirm) opts.onConfirm();
      };
      openModal('confirmModal');
    }

    // ---- Color picker helper ----
    var presetColors = [
      '#2ecc71','#22c55e','#16a34a','#22d3ee','#06b6d4','#0891b2','#3b82f6','#2563eb','#1d4ed8',
      '#8b5cf6','#7c3aed','#6d28d9','#ec4899','#db2777','#be185d','#ef4444','#dc2626','#b91c1c',
      '#f59e0b','#d97706','#b45309','#f97316','#ea580c','#c2410c','#e2e8f0','#94a3b8','#64748b'
    ];

    function initColorPicker(swatchId, hexId, popupId, presetGridId, customHexId, applyBtnId, targetInput) {
      var swatch = document.getElementById(swatchId);
      var hex = document.getElementById(hexId);
      var popup = document.getElementById(popupId);
      var grid = document.getElementById(presetGridId);
      var customHex = document.getElementById(customHexId);
      var applyBtn = document.getElementById(applyBtnId);

      if (!swatch || !hex) return;

      function setColor(color) {
        swatch.style.background = color;
        hex.value = color;
        if (targetInput) targetInput.value = color;
        // Update preview
        if (typeof updatePreview === 'function') updatePreview();
        // Update settings preview if modal open
        var settingsColor = document.getElementById('settingsColorHex');
        if (settingsColor && settingsColor.value === color) {
          document.getElementById('settingsColorSwatch').style.background = color;
        }
        popup.classList.remove('open');
      }

      swatch.addEventListener('click', function(e) {
        e.stopPropagation();
        popup.classList.toggle('open');
        // Build preset grid
        if (!grid.hasChildNodes()) {
          presetColors.forEach(function(c) {
            var div = document.createElement('div');
            div.className = 'preset';
            div.style.background = c;
            div.dataset.color = c;
            div.addEventListener('click', function(e) {
              e.stopPropagation();
              setColor(c);
            });
            grid.appendChild(div);
          });
        }
        // Highlight current color
        grid.querySelectorAll('.preset').forEach(function(el) {
          el.classList.toggle('active', el.dataset.color === hex.value);
        });
        customHex.value = hex.value.replace('#', '');
      });

      applyBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var val = customHex.value.trim();
        if (!val.startsWith('#')) val = '#' + val;
        if (/^#[0-9a-f]{6}$/i.test(val)) {
          setColor(val);
        } else {
          showToast('error', 'Invalid color', 'Please enter a valid hex color (e.g. #2ecc71)');
        }
      });

      document.addEventListener('click', function(e) {
        if (!popup.contains(e.target) && e.target !== swatch) popup.classList.remove('open');
      });

      // Initial color from target input
      if (targetInput && targetInput.value) {
        setColor(targetInput.value);
      }
    }

    // ---- Channel helpers ----
    function populateChannelSelect(select) {
      select.innerHTML = '<option value="">Select a channel…</option>';
      discordChannels.forEach(function(ch) {
        select.innerHTML += '<option value="' + ch.id + '">#' + ch.name + '</option>';
      });
    }

    async function loadChannels() {
      try {
        var data = await apiFetch('/channels');
        discordChannels = data.channels || [];
        isChannelsLoaded = true;
        populateChannelSelect(document.getElementById('channelSelect'));
        populateChannelSelect(document.getElementById('sendChannelSelect'));
        var status = await apiFetch('/status');
        if (status.channelId) {
          document.getElementById('channelSelect').value = status.channelId;
          document.getElementById('sendChannelSelect').value = status.channelId;
        }
      } catch (e) {
        showToast('error', 'Failed to load channels', e.message);
      }
    }

    // ---- Load status ----
    async function loadStatus() {
      var data = await apiFetch('/status');
      var badge = document.getElementById('statusBadge');
      var text = document.getElementById('statusText');
      if (data.locked) {
        badge.className = 'status-badge locked';
        text.textContent = '🔴 LOCKED';
      } else {
        badge.className = 'status-badge open';
        text.textContent = '🟢 OPEN';
      }

      document.getElementById('statChannel').textContent = data.channelName ? '#' + data.channelName : '—';
      document.getElementById('statMessage').textContent = data.messageId || '—';
      document.getElementById('statTotal').textContent = data.total;
      var unique = 0;
      for (var k in data.counts) { if (data.counts.hasOwnProperty(k)) unique += data.counts[k]; }
      document.getElementById('statUnique').textContent = unique;

      document.getElementById('count2').textContent = data.counts[2] || 0;
      document.getElementById('count3').textContent = data.counts[3] || 0;
      document.getElementById('count4').textContent = data.counts[4] || 0;
      document.getElementById('count5').textContent = data.counts[5] || 0;

      currentCounts = data.counts;
      currentTotal = data.total;
      currentMessageId = data.messageId;
      currentMessageExists = data.messageExists || false;

      // Update status card
      updateStatusCard(data);

      // Update toggle button
      var toggleBtn = document.getElementById('lockToggleBtn');
      if (toggleBtn) {
        var ts = toggleBtn.querySelector('.btn-text');
        if (ts) {
          if (data.locked) {
            ts.textContent = '🔓 Unlock';
            toggleBtn.className = 'btn btn-success';
          } else {
            ts.textContent = '🔒 Lock';
            toggleBtn.className = 'btn btn-primary';
          }
          toggleBtn.dataset.originalText = ts.textContent;
        }
      }

      var sendBtn = document.getElementById('sendDiscordBtn');
      if (sendBtn) {
        var st = sendBtn.querySelector('.btn-text');
        if (st) {
          st.textContent = data.messageId && data.messageExists ? '📤 Update Discord' : '📤 Create Discord';
          sendBtn.dataset.originalText = st.textContent;
        }
      }

      if (hasManage) {
        var statusEl = document.getElementById('channelStatus');
        var nameDisplay = document.getElementById('channelNameDisplay');
        if (data.channelId) {
          statusEl.textContent = '🟢 Connected';
          statusEl.style.background = 'rgba(34,197,94,0.15)';
          statusEl.style.color = '#22c55e';
          nameDisplay.textContent = '#' + (data.channelName || 'Unknown');
        } else {
          statusEl.textContent = '🔴 Not Connected';
          statusEl.style.background = 'rgba(239,68,68,0.15)';
          statusEl.style.color = '#ef4444';
          nameDisplay.textContent = 'None selected';
        }
        if (isChannelsLoaded && data.channelId) {
          document.getElementById('channelSelect').value = data.channelId;
          document.getElementById('sendChannelSelect').value = data.channelId;
        }
      }
      return data;
    }

    // ---- Update status card ----
    function updateStatusCard(data) {
      var card = document.getElementById('statusCard');
      var icon = document.getElementById('statusIcon');
      var title = document.getElementById('statusTitle');
      var badge = document.getElementById('statusBadgeMsg');
      var sub = document.getElementById('statusSub');
      var msgId = document.getElementById('msgIdDisplay');
      var channel = document.getElementById('msgChannelDisplay');
      var updated = document.getElementById('msgUpdatedDisplay');
      var actions = document.getElementById('statusActions');

      // Reset classes
      card.className = 'status-card';
      if (data.messageId && data.messageExists) {
        card.classList.add('active');
        icon.textContent = '✔';
        title.textContent = 'Active';
        badge.textContent = 'ACTIVE';
        sub.textContent = 'Message is available in Discord.';
        msgId.textContent = data.messageId;
        channel.textContent = data.channelName ? '#' + data.channelName : 'Unknown';
        updated.textContent = data.updatedAt ? new Date(data.updatedAt).toLocaleString() : '—';
        actions.innerHTML = `
          <button class="btn btn-primary btn-sm" id="statusUpdateBtn">📤 Update</button>
          <button class="btn btn-ghost btn-sm" id="statusOpenBtn">🔗 Open</button>
          <button class="btn btn-ghost btn-sm" id="statusRecreateBtn">📝 Recreate</button>
        `;
        document.getElementById('statusUpdateBtn').addEventListener('click', function() {
          document.getElementById('sendDiscordBtn').click();
        });
        document.getElementById('statusOpenBtn').addEventListener('click', function() {
          var url = 'https://discord.com/channels/' + (data.guildId || '@me') + '/' + data.channelId + '/' + data.messageId;
          window.open(url, '_blank');
        });
        document.getElementById('statusRecreateBtn').addEventListener('click', function() {
          openModal('sendDiscordModal');
          document.getElementById('sendChannelSelect').value = data.channelId || '';
          document.querySelector('.mode-card[data-mode="create"]').click();
          document.getElementById('sendTitle').value = 'Flag Call Results';
          document.getElementById('sendDescription').value = 'Live voting results for the current flag call.';
          document.getElementById('sendFooter').value = 'Click a button below to vote';
          updatePreview();
        });
      } else if (data.messageId && !data.messageExists) {
        card.classList.add('deleted');
        icon.textContent = '⚠';
        title.textContent = 'Message Missing';
        badge.textContent = 'DELETED';
        sub.textContent = 'The saved message no longer exists on Discord.';
        msgId.textContent = data.messageId + ' (deleted)';
        channel.textContent = data.channelName ? '#' + data.channelName : 'Unknown';
        updated.textContent = data.updatedAt ? new Date(data.updatedAt).toLocaleString() : '—';
        actions.innerHTML = `
          <button class="btn btn-danger btn-sm" id="statusRecreateBtn">📝 Recreate</button>
        `;
        document.getElementById('statusRecreateBtn').addEventListener('click', function() {
          openModal('sendDiscordModal');
          document.getElementById('sendChannelSelect').value = data.channelId || '';
          document.querySelector('.mode-card[data-mode="create"]').click();
          document.getElementById('sendTitle').value = 'Flag Call Results';
          document.getElementById('sendDescription').value = 'Live voting results for the current flag call.';
          document.getElementById('sendFooter').value = 'Click a button below to vote';
          updatePreview();
        });
      } else {
        card.classList.add('none');
        icon.textContent = '➕';
        title.textContent = 'No Message';
        badge.textContent = 'NO MESSAGE';
        sub.textContent = 'No Discord message has been created yet.';
        msgId.textContent = '—';
        channel.textContent = data.channelName ? '#' + data.channelName : 'Unknown';
        updated.textContent = '—';
        actions.innerHTML = `
          <button class="btn btn-primary btn-sm" id="statusCreateBtn">📝 Create Message</button>
        `;
        document.getElementById('statusCreateBtn').addEventListener('click', function() {
          openModal('sendDiscordModal');
          document.getElementById('sendChannelSelect').value = data.channelId || '';
          document.querySelector('.mode-card[data-mode="create"]').click();
          document.getElementById('sendTitle').value = 'Flag Call Results';
          document.getElementById('sendDescription').value = 'Live voting results for the current flag call.';
          document.getElementById('sendFooter').value = 'Click a button below to vote';
          updatePreview();
        });
      }
    }

    // ---- Load results ----
    async function loadResults() {
      var data = await apiFetch('/results');
      var container = document.getElementById('resultsContainer');
      var counts = [2,3,4,5];
      var html = '';
      for (var i=0; i<counts.length; i++) {
        var count = counts[i];
        var players = data.grouped[count] || [];
        var emoji = '🏳'.repeat(count);
        html += '<div class="results-group">';
        html += '<div class="header"><span>' + emoji + ' ' + count + ' Flags</span><span>' + players.length + '</span></div>';
        if (players.length === 0) html += '<div class="text-muted" style="font-size:0.85rem;">None</div>';
        else {
          for (var j=0; j<players.length; j++) {
            var p = players[j];
            var avatar = p.avatar || 'https://cdn.discordapp.com/embed/avatars/0.png';
            html += '<div class="player-item">';
            html += '<img src="' + avatar + '" onerror="this.src=\'https://cdn.discordapp.com/embed/avatars/0.png\'" />';
            html += '<span>' + p.username + '</span>';
            html += '<span style="color:var(--text-muted);font-size:0.75rem;margin-left:auto;">' + new Date(p.submittedAt).toLocaleTimeString() + '</span>';
            html += '</div>';
          }
        }
        html += '</div>';
      }
      container.innerHTML = html;
    }

    // ---- Load activity ----
    async function loadActivity() {
      var data = await apiFetch('/activity');
      var feed = document.getElementById('activityFeed');
      if (!data.activity || data.activity.length === 0) {
        feed.innerHTML = '<div class="text-muted">No recent activity.</div>';
        return;
      }
      var html = '';
      for (var i=0; i<Math.min(data.activity.length,20); i++) {
        var a = data.activity[i];
        var time = a.time ? new Date(a.time).toLocaleTimeString() : '';
        html += '<div class="activity-item"><span>' + a.text + '</span><span class="time">' + time + '</span></div>';
      }
      feed.innerHTML = html;
    }

    // ---- Refresh all ----
    async function refreshAll() {
      try {
        await loadStatus();
        await loadResults();
        await loadActivity();
        document.getElementById('errorBanner').style.display = 'none';
        if (firstLoad) {
          var loader = document.getElementById('hc-loading-screen');
          if (loader) {
            loader.classList.add('fade-out');
            setTimeout(function() { if (loader.parentNode) loader.remove(); }, 500);
          }
          firstLoad = false;
        }
        updatePreview();
      } catch (e) {
        console.error('Refresh failed:', e);
        if (firstLoad) {
          document.getElementById('errorBanner').style.display = 'block';
          document.getElementById('errorMessage').textContent = e.message || 'Failed to load data.';
        }
        throw e;
      }
    }

    document.getElementById('retryBtn').addEventListener('click', async function() {
      document.getElementById('errorBanner').style.display = 'none';
      await refreshAll();
    });

    // ---- Preview update ----
    function updatePreview() {
      document.getElementById('pCount2').textContent = currentCounts[2] || 0;
      document.getElementById('pCount3').textContent = currentCounts[3] || 0;
      document.getElementById('pCount4').textContent = currentCounts[4] || 0;
      document.getElementById('pCount5').textContent = currentCounts[5] || 0;
      document.getElementById('pTotal').textContent = currentTotal;

      var title = document.getElementById('sendTitle') ? document.getElementById('sendTitle').value || 'Flag Call Results' : 'Flag Call Results';
      var desc = document.getElementById('sendDescription') ? document.getElementById('sendDescription').value || '' : '';
      var footer = document.getElementById('sendFooter') ? document.getElementById('sendFooter').value || '' : '';
      var color = document.getElementById('colorHex') ? document.getElementById('colorHex').value || '#2ecc71' : '#2ecc71';

      var previewTitle = document.getElementById('previewTitle');
      var previewDesc = document.getElementById('previewDesc');
      var previewFooter = document.getElementById('previewFooter');
      var previewColorDot = document.getElementById('previewColorDot');
      var previewColorHex = document.getElementById('previewColorHex');
      if (previewTitle) previewTitle.textContent = title;
      if (previewDesc) previewDesc.textContent = desc;
      if (previewFooter) previewFooter.textContent = footer;
      if (previewColorDot) previewColorDot.style.background = color;
      if (previewColorHex) previewColorHex.textContent = color;

      // Update button preview
      var labels = {
        2: document.getElementById('btnLabel2') ? document.getElementById('btnLabel2').value || '2 Flags' : '2 Flags',
        3: document.getElementById('btnLabel3') ? document.getElementById('btnLabel3').value || '3 Flags' : '3 Flags',
        4: document.getElementById('btnLabel4') ? document.getElementById('btnLabel4').value || '4 Flags' : '4 Flags',
        5: document.getElementById('btnLabel5') ? document.getElementById('btnLabel5').value || '5 Flags' : '5 Flags'
      };
      var emojis = {
        2: document.getElementById('btnEmoji2') ? document.getElementById('btnEmoji2').value || '🏳' : '🏳',
        3: document.getElementById('btnEmoji3') ? document.getElementById('btnEmoji3').value || '🏳' : '🏳',
        4: document.getElementById('btnEmoji4') ? document.getElementById('btnEmoji4').value || '🏳' : '🏳',
        5: document.getElementById('btnEmoji5') ? document.getElementById('btnEmoji5').value || '🏳' : '🏳'
      };
      var colors = {
        2: document.getElementById('btnColor2') ? parseInt(document.getElementById('btnColor2').value, 10) : 1,
        3: document.getElementById('btnColor3') ? parseInt(document.getElementById('btnColor3').value, 10) : 3,
        4: document.getElementById('btnColor4') ? parseInt(document.getElementById('btnColor4').value, 10) : 2,
        5: document.getElementById('btnColor5') ? parseInt(document.getElementById('btnColor5').value, 10) : 4
      };
      var previewContainer = document.getElementById('buttonPreview');
      var btnClasses = ['primary','secondary','success','danger'];
      var btns = [
        { label: emojis[2] + ' ' + labels[2], cls: btnClasses[colors[2]-1] || 'primary' },
        { label: emojis[3] + ' ' + labels[3], cls: btnClasses[colors[3]-1] || 'success' },
        { label: emojis[4] + ' ' + labels[4], cls: btnClasses[colors[4]-1] || 'secondary' },
        { label: emojis[5] + ' ' + labels[5], cls: btnClasses[colors[5]-1] || 'danger' }
      ];
      previewContainer.innerHTML = btns.map(function(b) {
        return '<span class="btn-preview ' + b.cls + '">' + b.label + '</span>';
      }).join('');
    }

    // ---- Load settings for button config ----
    async function loadSettings() {
      if (!hasManage) return;
      try {
        var data = await apiFetch('/settings');
        var s = data.settings || {};
        document.getElementById('settingsColorHex').value = s.embedColor || '#2ecc71';
        document.getElementById('settingsColorSwatch').style.background = s.embedColor || '#2ecc71';
        document.getElementById('btnLabel2').value = s.buttonLabels ? s.buttonLabels[2] || '2 Flags' : '2 Flags';
        document.getElementById('btnLabel3').value = s.buttonLabels ? s.buttonLabels[3] || '3 Flags' : '3 Flags';
        document.getElementById('btnLabel4').value = s.buttonLabels ? s.buttonLabels[4] || '4 Flags' : '4 Flags';
        document.getElementById('btnLabel5').value = s.buttonLabels ? s.buttonLabels[5] || '5 Flags' : '5 Flags';
        document.getElementById('btnEmoji2').value = s.buttonEmojis ? s.buttonEmojis[2] || '🏳' : '🏳';
        document.getElementById('btnEmoji3').value = s.buttonEmojis ? s.buttonEmojis[3] || '🏳' : '🏳';
        document.getElementById('btnEmoji4').value = s.buttonEmojis ? s.buttonEmojis[4] || '🏳' : '🏳';
        document.getElementById('btnEmoji5').value = s.buttonEmojis ? s.buttonEmojis[5] || '🏳' : '🏳';
