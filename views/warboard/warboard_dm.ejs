    function insertVariable(varText) {
      const start = dmTextarea.selectionStart;
      const end = dmTextarea.selectionEnd;
      const text = dmTextarea.value;
      const before = text.substring(0, start);
      const after = text.substring(end);
      dmTextarea.value = before + varText + after;
      const newCursor = start + varText.length;
      dmTextarea.selectionStart = dmTextarea.selectionEnd = newCursor;
      dmTextarea.focus();
      updateCharCounter();
      clearTimeout(autoSaveTimer);
      autoSaveTimer = setTimeout(autoSave, 2000);
    }

