    // ============================================================
    // Build per‑player replacement data
    // ============================================================
    function buildPlayerData(player, buildingId, buildingData) {
      const buildings = window.buildingsData || [];
      const building = buildingData || buildings.find(b => b.id === (buildingId || player.building_id));
      const filled = building ? (buildingPlayersMap[building.id] || []).length : 0;
      const capacity = building ? building.capacity : 0;
      const slotsLeft = capacity - filled;

      return {
        player_name: player.name || 'Unknown',
        player_username: player.username || player.name || 'unknown',
        player_discord: `<@${player.discordId}>`,
        player_might: player.might || 'N/A',
        building_name: building ? building.name : (player.building_name || 'Not assigned'),
        building_capacity: capacity,
        building_filled: filled,
        building_slots_left: slotsLeft >= 0 ? slotsLeft : 0,
        guild_name: window.guildName || 'HyperCity',
        server_name: window.serverName || 'HyperCity Dashboard',
        officer_name: currentUser.username || 'Officer',
        current_date: new Date().toLocaleDateString(),
        current_time: new Date().toLocaleTimeString(),
        newline: '\n'
      };
    }

    // ============================================================
    // SEND DM
    // ============================================================
    async function sendDm(testMode = false) {
      if (isSending) {
        showToast('warning', 'Already sending...');
        return;
      }
      const content = dmTextarea.value.trim();
      if (!content) {
        showToast('warning', 'Message content is empty');
        return;
      }

      let recipients = [];
      let mode = currentSendMode;
      let buildingId = null;

      if (testMode) {
        if (!currentUserDiscordId) {
          showToast('error', 'Your Discord ID not found. Please login again.');
          return;
        }
        const userPlayer = allPlayers.find(p => p.discordId === currentUserDiscordId);
        if (userPlayer) {
          recipients = [userPlayer];
          buildingId = userPlayer.building_id || null;
        } else {
          recipients = [{ discordId: currentUserDiscordId, name: currentUser.username || 'You', building_id: null, might: 'N/A' }];
        }
        mode = 'test';
      } else {
        if (mode === 'player') {
          if (!selectedPlayer) {
            showToast('warning', 'Please select a player');
            return;
          }
          recipients = [selectedPlayer];
          buildingId = selectedPlayer.building_id || null;
        } else if (mode === 'building') {
          buildingId = dmBuildingSelect.value;
          if (!buildingId) {
            showToast('warning', 'Please select a building');
            return;
          }
          const players = buildingPlayersMap[buildingId] || [];
          if (players.length === 0) {
            showToast('warning', 'No players in this building with Discord IDs');
            return;
          }
          recipients = players;
        } else if (mode === 'all') {
          recipients = allPlayers;
          buildingId = null;
        } else {
          showToast('error', 'Unknown send mode');
          return;
        }
      }

      if (recipients.length === 0) {
        showToast('warning', 'No recipients selected');
        return;
      }

      // Duplicate protection (only normal sends)
      let filteredRecipients = recipients;
      if (!testMode) {
        const dupResult = await checkDuplicates(recipients, content);
        if (dupResult.hasDuplicates) {
          const duplicateCount = dupResult.duplicates.length;
          const skip = confirm(
            `⚠ Duplicate Detection\n\n${duplicateCount} players already received this template within the last 24 hours.\n\nClick OK to SKIP duplicate recipients (recommended).\nClick Cancel to send to everyone anyway.`
          );
          if (skip) {
            const dupIds = new Set(dupResult.duplicates.map(p => p.discordId));
            filteredRecipients = recipients.filter(p => !dupIds.has(p.discordId));
            if (filteredRecipients.length === 0) {
              showToast('warning', 'All recipients are duplicates. Sending cancelled.');
              return;
            }
            showToast('info', `Skipped ${duplicateCount} duplicate recipients. Sending to ${filteredRecipients.length} players.`);
          } else {
            showToast('info', `Sending to all ${recipients.length} players (including duplicates).`);
          }
        }
      }

      const finalRecipients = filteredRecipients;
      const count = finalRecipients.length;
      if (!testMode && count === 0) {
        showToast('warning', 'No recipients after filtering.');
        return;
      }

      const templateName = dmSelect.options[dmSelect.selectedIndex]?.text || 'Untitled';
      let confirmMsg = testMode ? '🧪 Send TEST DM to yourself?' : `Send DM to ${count} player(s)?`;
      confirmMsg += `\n\nMode: ${mode.charAt(0).toUpperCase() + mode.slice(1)}\n`;
      const samplePlayer = finalRecipients[0];
      const sampleBuilding = window.buildingsData.find(b => b.id === (buildingId || samplePlayer.building_id));
      confirmMsg += `Building: ${sampleBuilding ? sampleBuilding.name : (samplePlayer.building_name || 'Unknown')}\n`;
      confirmMsg += `Template: ${templateName}\n`;
      if (!testMode) confirmMsg += `Recipients: ${count} players\n\n`;
      confirmMsg += `Message preview:\n${content}`;

      const confirmed = confirm(confirmMsg);
      if (!confirmed) return;

      // Start sending
      await performSend(finalRecipients, testMode, buildingId, content);
    }

    // ============================================================
    // PERFORM SEND (with per‑player replacements)
    // ============================================================
    async function performSend(recipients, testMode, buildingId, content) {
      isSending = true;
      sendCancelled = false;
      sendStartTime = Date.now();
      failedDetails = [];

      dmActions.style.display = 'none';
      dmProgressPanel.style.display = 'block';
      dmProgressComplete.style.display = 'none';
      dmProgressFailedList.style.display = 'none';
      dmCancelSendBtn.style.display = 'inline-block';
      dmCancelSendBtn.disabled = false;
      dmCancelSendBtn.textContent = 'Cancel';

      dmSendBtn.disabled = true;
      dmTestSendBtn.disabled = true;
      dmSelect.disabled = true;
      dmPlayerSearch.disabled = true;
      dmBuildingSelect.disabled = true;

      const total = recipients.length;
      let sent = 0, success = 0, failed = 0;
      dmProgressTotal.textContent = total;
      dmProgressSent.textContent = '0';
      dmProgressRemaining.textContent = total;
      dmProgressSuccess.textContent = '0';
      dmProgressFailed.textContent = '0';
      dmProgressFill.style.width = '0%';
      dmProgressCurrentPlayer.textContent = '—';
      dmProgressETA.textContent = 'Calculating...';

      let buildingData = null;
      if (buildingId) {
        buildingData = window.buildingsData.find(b => b.id === buildingId);
      }

      const batchSize = 5;
      const delayMs = 2000;
      let startTime = Date.now();

      dmCancelSendBtn.onclick = function() {
        if (confirm('Cancel sending? This will stop the process.')) {
          sendCancelled = true;
          dmCancelSendBtn.disabled = true;
          dmCancelSendBtn.textContent = 'Cancelling...';
        }
      };

      function updateProgress() {
        const remaining = total - sent;
        dmProgressSent.textContent = sent;
        dmProgressRemaining.textContent = remaining;
        dmProgressSuccess.textContent = success;
        dmProgressFailed.textContent = failed;
        const progress = total > 0 ? (sent / total) * 100 : 0;
        dmProgressFill.style.width = Math.min(progress, 100) + '%';
        dmProgressCurrentPlayer.textContent = sent > 0 ? (recipients[sent-1]?.name || '—') : '—';

        if (sent > 0) {
          const elapsed = (Date.now() - startTime) / 1000;
          const rate = sent / elapsed;
          const remainingSecs = rate > 0 ? (remaining / rate) : 0;
          if (remainingSecs > 0) {
            const mins = Math.floor(remainingSecs / 60);
            const secs = Math.floor(remainingSecs % 60);
            dmProgressETA.textContent = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;
          } else {
            dmProgressETA.textContent = 'Almost done...';
          }
        }
      }

      function replaceVariables(template, player) {
        const data = buildPlayerData(player, buildingId, buildingData);
        let msg = template;
        for (const [key, value] of Object.entries(data)) {
          const placeholder = '{' + key + '}';
          msg = msg.replace(new RegExp(placeholder, 'g'), value);
        }
        return msg;
      }

      for (let i = 0; i < recipients.length; i += batchSize) {
        if (sendCancelled) break;
        const batch = recipients.slice(i, i + batchSize);
        await Promise.all(batch.map(async (player) => {
          if (sendCancelled) return;
          const playerMsg = replaceVariables(content, player);

          const payload = {
            mode: testMode ? 'test' : currentSendMode,
            recipientIds: [player.discordId],
            buildingId: (currentSendMode === 'building' ? buildingId : null),
            allBuildings: (currentSendMode === 'all'),
            templateContent: playerMsg,
            testMode: testMode
          };
          try {
            const res = await fetch('/api/warboard/dm-send', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
              body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (res.ok && data.sent > 0) {
              success++;
            } else {
              failed++;
              failedDetails.push({ player: player.name, reason: data.error || 'Unknown error' });
            }
          } catch (err) {
            failed++;
            failedDetails.push({ player: player.name, reason: err.message || 'Network error' });
          }
          sent++;
          updateProgress();
        }));
        if (i + batchSize < recipients.length && !sendCancelled) {
          await new Promise(resolve => setTimeout(resolve, delayMs));
        }
      }

      const endTime = Date.now();
      const timeTaken = ((endTime - sendStartTime) / 1000);
      const minutes = Math.floor(timeTaken / 60);
      const seconds = Math.floor(timeTaken % 60);
      const timeStr = minutes > 0 ? `${minutes}m ${seconds}s` : `${seconds}s`;

      dmCancelSendBtn.style.display = 'none';
      isSending = false;

      dmProgressComplete.style.display = 'block';
      dmCompleteTotal.textContent = recipients.length;
      dmCompleteSuccess.textContent = success;
      dmCompleteFailed.textContent = failed;
      dmCompleteTime.textContent = timeStr;

      if (failed > 0) {
        dmProgressFailedList.style.display = 'block';
        dmViewFailedBtn.onclick = function() {
          const detailsEl = dmFailedDetails;
          if (detailsEl.style.display === 'none') {
            detailsEl.style.display = 'block';
            detailsEl.innerHTML = failedDetails.map(f =>
              `<div style="padding:4px 0; border-bottom:1px solid var(--glass-border);"><strong>${escapeHtml(f.player)}</strong><br><span style="font-size:0.8rem; color:var(--text-muted);">Reason: ${escapeHtml(f.reason)}</span></div>`
            ).join('');
          } else {
            detailsEl.style.display = 'none';
          }
        };
        dmCompleteViewFailed.onclick = function() {
          const detailsEl = dmCompleteFailedDetails;
          if (detailsEl.style.display === 'none') {
            detailsEl.style.display = 'block';
            detailsEl.innerHTML = failedDetails.map(f =>
              `<div style="padding:4px 0; border-bottom:1px solid var(--glass-border);"><strong>${escapeHtml(f.player)}</strong><br><span style="font-size:0.8rem; color:var(--text-muted);">Reason: ${escapeHtml(f.reason)}</span></div>`
            ).join('');
          } else {
            detailsEl.style.display = 'none';
          }
        };
      } else {
        dmProgressFailedList.style.display = 'none';
      }

      dmSendBtn.disabled = false;
      dmTestSendBtn.disabled = false;
      dmSelect.disabled = false;
      dmPlayerSearch.disabled = false;
      dmBuildingSelect.disabled = false;

      if (testMode) {
        if (success > 0) {
          showToast('success', '✅ Test DM sent successfully.');
        } else {
          const errMsg = failedDetails.length > 0 ? failedDetails[0].reason : 'Unknown error';
          showToast('error', `❌ Unable to send test DM.\nReason: ${errMsg}`);
        }
      } else {
        showToast(success > 0 ? 'success' : 'error', `Sent ${success} DMs (${failed} failed)`);
      }
    }

