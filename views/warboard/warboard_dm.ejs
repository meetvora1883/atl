<!-- ============================================================
     DISCORD DM SYSTEM – Final (Per‑Player Replacements)
     ============================================================ -->

<!-- Tabs -->
<div class="dm-tabs">
  <button class="dm-tab active" data-tab="templates">Templates</button>
  <button class="dm-tab" data-tab="history">History</button>
</div>

<!-- TEMPLATES TAB -->
<div class="dm-tab-content" id="dmTabTemplates">
  <!-- Template Management Toolbar -->
  <div class="dm-toolbar">
    <select id="dmTemplateSelect" class="dm-template-select">
      <option value="">-- Select Template --</option>
    </select>
    <button class="btn btn-ghost btn-sm" id="dmSaveTemplateBtn"><i class="bi bi-save"></i> Save</button>
    <button class="btn btn-ghost btn-sm" id="dmSaveAsTemplateBtn"><i class="bi bi-files"></i> Save As</button>
    <button class="btn btn-ghost btn-sm" id="dmDeleteTemplateBtn"><i class="bi bi-trash3"></i> Delete</button>
    <button class="btn btn-ghost btn-sm" id="dmSetDefaultBtn"><i class="bi bi-star"></i> Set Default</button>
    <span class="dm-last-edited">Last edited: <span id="dmLastEdited">Never</span></span>
  </div>

  <!-- Editor -->
  <div class="dm-editor-wrap">
    <textarea id="dmMessageContent" class="dm-message-textarea" placeholder="Write your message here... Use the variable buttons below to insert placeholders."></textarea>
    <div class="dm-char-counter" id="dmCharCounter">0 / 1500</div>
  </div>

  <!-- Variables -->
  <div class="dm-variables-group">
    <div class="var-group">
      <span class="var-group-label">Player</span>
      <button class="var-btn" data-var="{player_name}">{player_name}</button>
      <button class="var-btn" data-var="{player_username}">{player_username}</button>
      <button class="var-btn" data-var="{player_discord}">{player_discord}</button>
      <button class="var-btn" data-var="{player_might}">{player_might}</button>
    </div>
    <div class="var-group">
      <span class="var-group-label">Building</span>
      <button class="var-btn" data-var="{building_name}">{building_name}</button>
      <button class="var-btn" data-var="{building_capacity}">{building_capacity}</button>
      <button class="var-btn" data-var="{building_filled}">{building_filled}</button>
      <button class="var-btn" data-var="{building_slots_left}">{building_slots_left}</button>
    </div>
    <div class="var-group">
      <span class="var-group-label">Server</span>
      <button class="var-btn" data-var="{guild_name}">{guild_name}</button>
      <button class="var-btn" data-var="{server_name}">{server_name}</button>
      <button class="var-btn" data-var="{officer_name}">{officer_name}</button>
    </div>
    <div class="var-group">
      <span class="var-group-label">Time</span>
      <button class="var-btn" data-var="{current_date}">{current_date}</button>
      <button class="var-btn" data-var="{current_time}">{current_time}</button>
    </div>
    <div class="var-group">
      <span class="var-group-label">Formatting</span>
      <button class="var-btn" data-var="{newline}">{newline}</button>
    </div>
  </div>

  <!-- Send Mode -->
  <div class="dm-send-mode">
    <label><input type="radio" name="sendMode" value="player" checked> Selected Player</label>
    <label><input type="radio" name="sendMode" value="building"> Selected Building</label>
    <label><input type="radio" name="sendMode" value="all"> All Buildings</label>
  </div>

  <!-- Player Selector -->
  <div class="dm-player-selector" id="dmPlayerSelector">
    <div class="dm-player-search-wrap">
      <i class="bi bi-search"></i>
      <input type="text" id="dmPlayerSearch" class="dm-player-search" placeholder="Search by name, ID, building, or might..." />
    </div>
    <div class="dm-player-list" id="dmPlayerList"></div>
    <div class="dm-player-info" id="dmPlayerInfo">
      <div class="dm-player-info-card" id="dmPlayerInfoCard">
        <div class="player-avatar-wrapper">
          <img id="dmInfoAvatar" src="" alt="Avatar" />
        </div>
        <div class="player-details">
          <div class="player-name" id="dmInfoName"></div>
          <div class="player-discord" id="dmInfoDiscord"></div>
          <div class="player-building" id="dmInfoBuilding"></div>
          <div class="player-might" id="dmInfoMight"></div>
          <div class="player-status" id="dmInfoStatus"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Building Selector -->
  <div class="dm-building-selector" id="dmBuildingSelector">
    <label>Building</label>
    <select id="dmBuildingSelect" class="dm-building-dropdown"></select>
    <div class="dm-building-players">
      <span class="dm-building-player-count" id="dmBuildingPlayerCount">Players (0)</span>
      <div id="dmBuildingPlayerList" class="dm-building-player-list"></div>
    </div>
  </div>

  <!-- Preview -->
  <div class="dm-preview-wrapper" id="dmPreviewWrapper">
    <div class="dm-preview-header">
      <span>Preview</span>
      <span id="dmPreviewRecipient" class="dm-preview-recipient">No recipient</span>
      <span id="dmPreviewBuilding" class="dm-preview-building"></span>
    </div>
    <div class="dm-preview-bubble" id="dmPreviewBubble">
      <div class="dm-preview-content" id="dmPreviewContent">
        <div class="dm-preview-empty">Select a player or send mode to preview.</div>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="dm-actions" id="dmActions">
    <button class="btn btn-primary" id="dmSendBtn"><i class="bi bi-send"></i> Send DM</button>
    <button class="btn btn-ghost" id="dmTestSendBtn"><i class="bi bi-bug"></i> Send Test DM</button>
    <button class="btn btn-ghost" id="dmPreviewBtn"><i class="bi bi-eye"></i> Show Preview</button>
    <button class="btn btn-ghost" id="dmResetBtn"><i class="bi bi-arrow-counterclockwise"></i> Reset</button>
    <span class="char-counter" id="dmCharCounter2">0 / 1500</span>
  </div>

  <!-- Progress Panel -->
  <div class="dm-progress-panel" id="dmProgressPanel" style="display:none;">
    <div class="dm-progress-header">
      <span>Sending Discord Messages</span>
      <span id="dmProgressETA">Calculating...</span>
    </div>
    <div class="dm-progress-bar-wrap">
      <div class="dm-progress-fill" id="dmProgressFill" style="width:0%;"></div>
    </div>
    <div class="dm-progress-stats">
      <div class="dm-stat-item"><span class="label">Total</span><span class="value" id="dmProgressTotal">0</span></div>
      <div class="dm-stat-item"><span class="label">Sent</span><span class="value" id="dmProgressSent">0</span></div>
      <div class="dm-stat-item"><span class="label">Remaining</span><span class="value" id="dmProgressRemaining">0</span></div>
      <div class="dm-stat-item"><span class="label">Success</span><span class="value" id="dmProgressSuccess">0</span></div>
      <div class="dm-stat-item"><span class="label">Failed</span><span class="value" id="dmProgressFailed">0</span></div>
    </div>
    <div class="dm-progress-current">
      <span class="label">Current Player</span>
      <span class="value" id="dmProgressCurrentPlayer">—</span>
    </div>
    <div class="dm-progress-failed-list" id="dmProgressFailedList" style="display:none;">
      <button class="btn btn-ghost btn-sm" id="dmViewFailedBtn">View Failed Players</button>
      <div id="dmFailedDetails" style="display:none; margin-top:6px; max-height:150px; overflow-y:auto; background:var(--bg-2); padding:6px; border-radius:6px; border:1px solid var(--glass-border);"></div>
    </div>
    <div class="dm-progress-actions">
      <button class="btn btn-danger btn-sm" id="dmCancelSendBtn" style="display:none;">Cancel</button>
    </div>
    <div class="dm-progress-complete" id="dmProgressComplete" style="display:none;">
      <div style="font-weight:700; font-size:1.1rem;">✅ Delivery Complete</div>
      <div class="dm-progress-stats" style="margin:8px 0;">
        <span class="stat-item">Total: <strong id="dmCompleteTotal">0</strong></span>
        <span class="stat-item">Success: <strong id="dmCompleteSuccess">0</strong></span>
        <span class="stat-item">Failed: <strong id="dmCompleteFailed">0</strong></span>
        <span class="stat-item">Time: <strong id="dmCompleteTime">0s</strong></span>
      </div>
      <button class="btn btn-ghost btn-sm" id="dmCompleteViewFailed">View Failed Players</button>
      <div id="dmCompleteFailedDetails" style="display:none; margin-top:6px; max-height:150px; overflow-y:auto; background:var(--bg-2); padding:6px; border-radius:6px; border:1px solid var(--glass-border);"></div>
      <button class="btn btn-primary btn-sm" id="dmCompleteOk" style="margin-top:8px;">OK</button>
    </div>
  </div>
</div>

<!-- HISTORY TAB -->
<div class="dm-tab-content dm-hidden" id="dmTabHistory">
  <div class="dm-history-toolbar">
    <input type="text" id="dmHistorySearch" class="dm-history-search" placeholder="Search history..." />
    <button class="btn btn-ghost btn-sm" id="dmHistoryRefresh"><i class="bi bi-arrow-clockwise"></i></button>
  </div>
  <div class="dm-history-list" id="dmHistoryList">
    <div class="dm-history-empty">Loading history...</div>
  </div>
  <div class="dm-history-pagination" id="dmHistoryPagination"></div>
</div>

<!-- ============================================================
     JAVASCRIPT – Per‑Player Replacements (Final)
     ============================================================ -->
<script>
  (function() {
    // ----- DOM refs -----
    const dmTextarea = document.getElementById('dmMessageContent');
    const dmSelect = document.getElementById('dmTemplateSelect');
    const dmCharCounter = document.getElementById('dmCharCounter');
    const dmCharCounter2 = document.getElementById('dmCharCounter2');
    const dmLastEdited = document.getElementById('dmLastEdited');
    const dmPreviewWrapper = document.getElementById('dmPreviewWrapper');
    const dmPreviewContent = document.getElementById('dmPreviewContent');
    const dmPreviewRecipient = document.getElementById('dmPreviewRecipient');
    const dmPreviewBuilding = document.getElementById('dmPreviewBuilding');
    const dmPlayerSearch = document.getElementById('dmPlayerSearch');
    const dmPlayerList = document.getElementById('dmPlayerList');
    const dmPlayerInfoCard = document.getElementById('dmPlayerInfoCard');
    const dmInfoAvatar = document.getElementById('dmInfoAvatar');
    const dmInfoName = document.getElementById('dmInfoName');
    const dmInfoDiscord = document.getElementById('dmInfoDiscord');
    const dmInfoBuilding = document.getElementById('dmInfoBuilding');
    const dmInfoMight = document.getElementById('dmInfoMight');
    const dmInfoStatus = document.getElementById('dmInfoStatus');
    const dmSendBtn = document.getElementById('dmSendBtn');
    const dmTestSendBtn = document.getElementById('dmTestSendBtn');
    const dmPreviewBtn = document.getElementById('dmPreviewBtn');
    const dmResetBtn = document.getElementById('dmResetBtn');
    const dmBuildingSelect = document.getElementById('dmBuildingSelect');
    const dmBuildingPlayerList = document.getElementById('dmBuildingPlayerList');
    const dmBuildingPlayerCount = document.getElementById('dmBuildingPlayerCount');
    const dmHistoryList = document.getElementById('dmHistoryList');
    const dmHistoryPagination = document.getElementById('dmHistoryPagination');
    const dmHistorySearch = document.getElementById('dmHistorySearch');
    const dmProgressPanel = document.getElementById('dmProgressPanel');
    const dmProgressFill = document.getElementById('dmProgressFill');
    const dmProgressTotal = document.getElementById('dmProgressTotal');
    const dmProgressSent = document.getElementById('dmProgressSent');
    const dmProgressRemaining = document.getElementById('dmProgressRemaining');
    const dmProgressSuccess = document.getElementById('dmProgressSuccess');
    const dmProgressFailed = document.getElementById('dmProgressFailed');
    const dmProgressCurrentPlayer = document.getElementById('dmProgressCurrentPlayer');
    const dmProgressETA = document.getElementById('dmProgressETA');
    const dmCancelSendBtn = document.getElementById('dmCancelSendBtn');
    const dmProgressComplete = document.getElementById('dmProgressComplete');
    const dmCompleteTotal = document.getElementById('dmCompleteTotal');
    const dmCompleteSuccess = document.getElementById('dmCompleteSuccess');
    const dmCompleteFailed = document.getElementById('dmCompleteFailed');
    const dmCompleteTime = document.getElementById('dmCompleteTime');
    const dmCompleteViewFailed = document.getElementById('dmCompleteViewFailed');
    const dmCompleteFailedDetails = document.getElementById('dmCompleteFailedDetails');
    const dmCompleteOk = document.getElementById('dmCompleteOk');
    const dmViewFailedBtn = document.getElementById('dmViewFailedBtn');
    const dmFailedDetails = document.getElementById('dmFailedDetails');
    const dmProgressFailedList = document.getElementById('dmProgressFailedList');
    const dmActions = document.getElementById('dmActions');

    // ----- Constants -----
    const MAX_CHARS = 1500;

    // ----- State -----
    let currentTemplateId = null;
    let allTemplates = [];
    let previewCache = {};
    let lastSavedContent = '';
    let autoSaveTimer = null;
    let isSending = false;
    let sendCancelled = false;
    let selectedPlayer = null;
    let allPlayers = [];
    let buildingPlayersMap = {};
    let currentSendMode = 'player';
    let currentHistoryPage = 1;
    let totalHistoryPages = 1;
    let previewVisible = false;
    let searchDebounceTimer = null;
    let currentUser = window.currentUser || {};
    let currentUserDiscordId = currentUser.discord_id || null;
    let failedDetails = [];
    let sendStartTime = null;

    // ----- Helper: escape HTML -----
    function escapeHtml(text) {
      if (text === null || text === undefined) return '';
      const str = String(text);
      const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
      return str.replace(/[&<>"']/g, function(m) { return map[m]; });
    }

    // ----- Helper: show toast -----
    function showToast(type, title, message) {
      if (window.showToast) window.showToast(type, title, message);
      else console.log(`[${type}] ${title}: ${message}`);
    }

    // ----- Helper: set loading state -----
    function setLoading(btn, text) {
      if (!btn) return function(){};
      const original = btn.innerHTML;
      btn.disabled = true;
      btn.classList.add('btn-loading');
      btn.innerHTML = `<span class="spinner-border-sm"></span> ${text}`;
      return function restore() {
        btn.disabled = false;
        btn.classList.remove('btn-loading');
        btn.innerHTML = original;
      };
    }

    // ----- Tabs -----
    document.querySelectorAll('.dm-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        document.querySelectorAll('.dm-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        const target = this.dataset.tab;
        document.querySelectorAll('.dm-tab-content').forEach(c => c.classList.add('dm-hidden'));
        document.getElementById('dmTab' + target.charAt(0).toUpperCase() + target.slice(1)).classList.remove('dm-hidden');
        if (target === 'history') loadHistory();
      });
    });

    // ============================================================
    // TEMPLATES (unchanged)
    // ============================================================
    async function loadTemplates() {
      try {
        const res = await fetch('/api/warboard/dm-templates', {
          headers: { 'x-csrf-token': csrfToken }
        });
        if (res.ok) {
          allTemplates = await res.json();
          const currentVal = dmSelect.value;
          dmSelect.innerHTML = '<option value="">-- Select Template --</option>';
          let defaultId = null;
          allTemplates.forEach(t => {
            const opt = document.createElement('option');
            opt.value = t.id;
            opt.textContent = t.name + (t.is_default ? ' ★' : '');
            dmSelect.appendChild(opt);
            if (t.is_default) defaultId = t.id;
          });
          if (currentVal && allTemplates.some(t => t.id == currentVal)) {
            dmSelect.value = currentVal;
          } else if (defaultId) {
            dmSelect.value = defaultId;
          }
          if (dmSelect.value) {
            const selected = allTemplates.find(t => t.id == dmSelect.value);
            if (selected) {
              dmTextarea.value = selected.content;
              currentTemplateId = selected.id;
              updateCharCounter();
              lastSavedContent = selected.content;
              dmLastEdited.textContent = selected.updated_at ? new Date(selected.updated_at).toLocaleString() : 'Never';
            }
          } else {
            restoreDraft();
          }
        }
      } catch (e) {
        console.warn('Failed to load templates:', e);
      }
    }

    dmSelect.addEventListener('change', function() {
      const id = this.value;
      if (!id) {
        dmTextarea.value = '';
        currentTemplateId = null;
        updateCharCounter();
        return;
      }
      const found = allTemplates.find(t => t.id == id);
      if (found) {
        dmTextarea.value = found.content;
        currentTemplateId = found.id;
        updateCharCounter();
        lastSavedContent = found.content;
        dmLastEdited.textContent = found.updated_at ? new Date(found.updated_at).toLocaleString() : 'Never';
        localStorage.removeItem('warboard_dm_draft');
      }
    });

    async function saveTemplate(asNew = false) {
      const content = dmTextarea.value.trim();
      if (!content) { showToast('warning', 'Message content is empty'); return; }
      const defaultName = asNew ? '' : (dmSelect.options[dmSelect.selectedIndex]?.text || '');
      const name = prompt('Enter template name:', defaultName);
      if (!name) return;
      const isDefault = confirm('Set as default template?');
      const id = asNew ? null : currentTemplateId;
      const payload = { name, content, is_default: isDefault };
      if (id) payload.id = id;
      try {
        const restore = setLoading(document.getElementById('dmSaveTemplateBtn'), 'Saving');
        const res = await fetch('/api/warboard/dm-templates', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
          body: JSON.stringify(payload)
        });
        restore();
        if (res.ok) {
          showToast('success', 'Template saved');
          await loadTemplates();
          const data = await res.json();
          if (data.id) {
            dmSelect.value = data.id;
            currentTemplateId = data.id;
          }
        } else {
          const err = await res.json();
          showToast('error', 'Failed to save: ' + err.error);
        }
      } catch (e) {
        showToast('error', 'Network error: ' + e.message);
      }
    }

    async function deleteTemplate() {
      if (!currentTemplateId) { showToast('warning', 'No template selected'); return; }
      const confirmed = confirm('Are you sure you want to delete this template?');
      if (!confirmed) return;
      try {
        const restore = setLoading(document.getElementById('dmDeleteTemplateBtn'), 'Deleting');
        const res = await fetch('/api/warboard/dm-templates/' + currentTemplateId, {
          method: 'DELETE',
          headers: { 'x-csrf-token': csrfToken }
        });
        restore();
        if (res.ok) {
          showToast('success', 'Template deleted');
          await loadTemplates();
          dmTextarea.value = '';
          currentTemplateId = null;
          updateCharCounter();
        } else {
          const err = await res.json();
          showToast('error', 'Failed to delete: ' + err.error);
        }
      } catch (e) {
        showToast('error', 'Network error: ' + e.message);
      }
    }

    async function setDefault() {
      if (!currentTemplateId) { showToast('warning', 'No template selected'); return; }
      const confirmed = confirm('Set this template as the default?');
      if (!confirmed) return;
      try {
        const res = await fetch('/api/warboard/dm-templates', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
          body: JSON.stringify({ id: currentTemplateId, is_default: true })
        });
        if (res.ok) {
          showToast('success', 'Default template updated');
          await loadTemplates();
          dmSelect.value = currentTemplateId;
        } else {
          const err = await res.json();
          showToast('error', 'Failed: ' + err.error);
        }
      } catch (e) {
        showToast('error', 'Network error');
      }
    }

    // Auto-save
    function autoSave() {
      const content = dmTextarea.value;
      if (content !== lastSavedContent && content.trim() !== '') {
        localStorage.setItem('warboard_dm_draft', content);
        lastSavedContent = content;
        dmLastEdited.textContent = new Date().toLocaleString();
      }
    }
    function restoreDraft() {
      const draft = localStorage.getItem('warboard_dm_draft');
      if (draft && !dmTextarea.value) {
        dmTextarea.value = draft;
        updateCharCounter();
        lastSavedContent = draft;
      }
    }

    function updateCharCounter() {
      const len = dmTextarea.value.length;
      const text = len + ' / ' + MAX_CHARS;
      dmCharCounter.textContent = text;
      dmCharCounter2.textContent = text;
      dmCharCounter.className = 'dm-char-counter';
      if (len >= MAX_CHARS) dmCharCounter.classList.add('danger');
      else if (len >= 1350) dmCharCounter.classList.add('warning');
    }

    function enforceCharLimit() {
      if (dmTextarea.value.length > MAX_CHARS) {
        dmTextarea.value = dmTextarea.value.slice(0, MAX_CHARS);
        updateCharCounter();
      }
    }

    // ============================================================
    // LOAD PLAYERS
    // ============================================================
    async function loadPlayers() {
      try {
        const res = await fetch('/api/warboard/dm-players-list', {
          headers: { 'x-csrf-token': csrfToken }
        });
        if (res.ok) {
          const players = await res.json();
          allPlayers = players;
          buildingPlayersMap = {};
          players.forEach(p => {
            const bId = p.building_id || 'unassigned';
            if (!buildingPlayersMap[bId]) buildingPlayersMap[bId] = [];
            buildingPlayersMap[bId].push({ ...p, buildingId: bId });
          });
          populateBuildingDropdown();
          renderPlayerList(allPlayers);

          if (currentUserDiscordId) {
            const currentUserPlayer = allPlayers.find(p => p.discordId === currentUserDiscordId);
            if (currentUserPlayer && !selectedPlayer) {
              selectedPlayer = currentUserPlayer;
              renderPlayerList(allPlayers);
              updatePlayerInfoCard(selectedPlayer);
            }
          }
        }
      } catch (e) {
        console.warn('Failed to load players:', e);
      }
    }

    function populateBuildingDropdown() {
      const currentVal = dmBuildingSelect.value;
      dmBuildingSelect.innerHTML = '<option value="">-- Select a building --</option>';
      const buildings = window.buildingsData || [];
      if (buildings.length === 0) {
        dmBuildingSelect.innerHTML = '<option value="">No buildings loaded</option>';
        return;
      }
      buildings.forEach(b => {
        const players = buildingPlayersMap[b.id] || [];
        const filled = players.length;
        const opt = document.createElement('option');
        opt.value = b.id;
        opt.textContent = b.name + '  (' + filled + '/' + b.capacity + ')';
        dmBuildingSelect.appendChild(opt);
      });
      if (currentVal && dmBuildingSelect.querySelector(`option[value="${currentVal}"]`)) {
        dmBuildingSelect.value = currentVal;
      }
      if (dmBuildingSelect.value) {
        dmBuildingSelect.dispatchEvent(new Event('change'));
      }
    }

    function renderPlayerList(players) {
      dmPlayerList.innerHTML = '';
      if (players.length === 0) {
        dmPlayerList.innerHTML = `
          <div class="dm-list-empty">No players found.</div>
          <div class="dm-list-hint" style="font-size:0.8rem; color:var(--text-muted); padding:4px 12px 8px;">Try another name, Discord ID, Building, or Might.</div>
        `;
        return;
      }
      players.forEach(p => {
        const div = document.createElement('div');
        div.className = 'player-item';
        div.dataset.id = p.discordId;
        if (selectedPlayer && selectedPlayer.discordId === p.discordId) {
          div.classList.add('selected');
        }
        const avatar = p.avatar || `https://cdn.discordapp.com/embed/avatars/${Math.floor(Math.random()*6)}.png`;
        div.innerHTML = `
          <img src="${escapeHtml(avatar)}" alt="Avatar" />
          <div class="pinfo">
            <div class="pname">${escapeHtml(p.name)}</div>
            <div class="pdetails">${escapeHtml(p.building_name || 'Unassigned')} • ${escapeHtml(p.might || 'N/A')} Might</div>
          </div>
        `;
        div.addEventListener('click', () => selectPlayer(p));
        dmPlayerList.appendChild(div);
      });
    }

    dmPlayerSearch.addEventListener('input', function() {
      clearTimeout(searchDebounceTimer);
      searchDebounceTimer = setTimeout(() => {
        const query = this.value.trim();
        if (!query) {
          renderPlayerList(allPlayers);
          return;
        }
        const lower = query.toLowerCase();
        const filtered = allPlayers.filter(p => {
          const name = (p.name || '').toLowerCase();
          const id = (p.discordId || '').toLowerCase();
          const building = (p.building_name || '').toLowerCase();
          const might = (p.might || '').toLowerCase();
          return name.includes(lower) || id.includes(lower) || building.includes(lower) || might.includes(lower);
        });
        renderPlayerList(filtered);
      }, 250);
    });

    function selectPlayer(player) {
      selectedPlayer = player;
      renderPlayerList(allPlayers);
      updatePlayerInfoCard(player);
      if (previewVisible) buildPreview(player.discordId);
    }

    function updatePlayerInfoCard(player) {
      dmInfoAvatar.src = player.avatar || `https://cdn.discordapp.com/embed/avatars/${Math.floor(Math.random()*6)}.png`;
      dmInfoName.textContent = player.name;
      dmInfoDiscord.textContent = 'Discord: @' + player.name;
