    // ============================================================
    // HISTORY (unchanged)
    // ============================================================
    async function loadHistory(page = 1) {
      try {
        const search = dmHistorySearch.value.trim();
        const res = await fetch(`/api/warboard/dm-history?page=${page}&search=${encodeURIComponent(search)}`, {
          headers: { 'x-csrf-token': csrfToken }
        });
        if (res.ok) {
          const data = await res.json();
          renderHistory(data.items, data.page, data.pages);
          currentHistoryPage = data.page;
          totalHistoryPages = data.pages;
        }
      } catch (e) {
        dmHistoryList.innerHTML = '<div class="dm-history-empty">Failed to load history.</div>';
      }
    }

    function renderHistory(items, page, pages) {
      if (items.length === 0) {
        dmHistoryList.innerHTML = '<div class="dm-history-empty">No history found.</div>';
        dmHistoryPagination.innerHTML = '';
        return;
      }
      dmHistoryList.innerHTML = items.map(item => `
        <div class="dm-history-item">
          <div class="h-left">
            <div class="h-title">${escapeHtml(item.template_name || 'Bulk DM')}</div>
            <div class="h-details">${item.recipients} recipients • ${escapeHtml(item.mode)}</div>
          </div>
          <div class="h-right">
            <div class="h-stats">
              <span class="success">${item.success}</span> / <span class="failed">${item.failed}</span>
            </div>
            <div class="h-time">${new Date(item.created_at).toLocaleString()}</div>
          </div>
        </div>
      `).join('');

      let pagHtml = '';
      if (pages > 1) {
        const prev = page > 1 ? page - 1 : 1;
        const next = page < pages ? page + 1 : pages;
        pagHtml += `<button class="page-btn" data-page="${prev}">‹</button>`;
        const pageSet = new Set();
        for (let i = 1; i <= Math.min(3, pages); i++) pageSet.add(i);
        for (let i = Math.max(1, page - 1); i <= Math.min(pages, page + 1); i++) pageSet.add(i);
        for (let i = Math.max(1, pages - 2); i <= pages; i++) pageSet.add(i);
        const sorted = Array.from(pageSet).sort((a,b) => a - b);
        let last = 0;
        sorted.forEach(p => {
          if (p - last > 1) pagHtml += '<span class="page-ellipsis">…</span>';
          pagHtml += `<button class="page-btn ${p === page ? 'active' : ''}" data-page="${p}">${p}</button>`;
          last = p;
        });
        pagHtml += `<button class="page-btn" data-page="${next}">›</button>`;
      }
      dmHistoryPagination.innerHTML = pagHtml;
      dmHistoryPagination.querySelectorAll('.page-btn').forEach(btn => {
        btn.addEventListener('click', () => loadHistory(parseInt(btn.dataset.page)));
      });
    }

    dmHistorySearch.addEventListener('input', () => loadHistory(1));
    document.getElementById('dmHistoryRefresh').addEventListener('click', () => loadHistory(currentHistoryPage));

