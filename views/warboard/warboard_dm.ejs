    // ============================================================
    // PREVIEW (unchanged)
    // ============================================================
    async function buildPreview(discordId) {
      if (!discordId) {
        dmPreviewContent.innerHTML = '<div class="dm-preview-empty">Select a player to preview.</div>';
        dmPreviewRecipient.textContent = 'No recipient';
        dmPreviewBuilding.textContent = '';
        return;
      }
      const currentContent = dmTextarea.value;
      if (previewCache._lastContent !== currentContent) {
        previewCache = {};
        previewCache._lastContent = currentContent;
      }
      if (previewCache[discordId]) {
        renderPreview(previewCache[discordId]);
        return;
      }
      try {
        const res = await fetch('/api/warboard/dm-preview/' + discordId, {
          headers: { 'x-csrf-token': csrfToken }
        });
        if (!res.ok) throw new Error('Failed to fetch preview data');
        const data = await res.json();
        previewCache[discordId] = data;
        renderPreview(data);
      } catch (e) {
        dmPreviewContent.innerHTML = '<div class="dm-preview-error">Failed to load preview: ' + escapeHtml(e.message) + '</div>';
      }
    }

    function renderPreview(data) {
      const template = dmTextarea.value;
      if (!template || typeof template !== 'string') {
        dmPreviewContent.innerHTML = '<div class="dm-preview-empty">Write a message to preview.</div>';
        dmPreviewRecipient.textContent = 'No template';
        dmPreviewBuilding.textContent = '';
        return;
      }

      let rendered = escapeHtml(template);
      for (const [key, value] of Object.entries(data)) {
        const placeholder = '{' + key + '}';
        const safeValue = escapeHtml(value !== undefined && value !== null ? String(value) : '');
        rendered = rendered.replace(new RegExp(placeholder, 'g'), safeValue);
      }
      rendered = rendered.replace(/\{newline\}/g, '\n');
      rendered = rendered
        .replace(/\n/g, '<br>')
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/`(.*?)`/g, '<code>$1</code>')
        .replace(/@([^\s]+)/g, '<span class="mention">@$1</span>');

      dmPreviewContent.innerHTML = rendered;
      dmPreviewRecipient.textContent = data.player_name || 'Unknown';
      dmPreviewBuilding.textContent = data.building_name ? '🏰 ' + data.building_name : '';
    }

    function getPreviewPlayer() {
      if (currentSendMode === 'player') {
        if (selectedPlayer) return selectedPlayer;
        if (currentUserDiscordId) {
          const user = allPlayers.find(p => p.discordId === currentUserDiscordId);
          if (user) return user;
        }
        return allPlayers.length > 0 ? allPlayers[0] : null;
      } else if (currentSendMode === 'building') {
        const buildingId = dmBuildingSelect.value;
        if (!buildingId) return null;
        let players = buildingPlayersMap[buildingId] || [];
        if (currentUserDiscordId) {
          const user = players.find(p => p.discordId === currentUserDiscordId);
          if (user) return user;
        }
        return players.length > 0 ? players[0] : null;
      } else if (currentSendMode === 'all') {
        if (currentUserDiscordId) {
          const user = allPlayers.find(p => p.discordId === currentUserDiscordId);
          if (user) return user;
        }
        return allPlayers.length > 0 ? allPlayers[0] : null;
      }
      return null;
    }

