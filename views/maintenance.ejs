<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Maintenance · HyperCity</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="maintenance-page">
    <div style="text-align: center; position: relative; z-index: 1;">
      <div style="font-family: 'Poppins', sans-serif; font-size: 3.2rem; font-weight: 700; margin-bottom: 12px; background: linear-gradient(135deg, #5865f2, #ff5fae); -webkit-background-clip: text; background-clip: text; color: transparent;">
        HyperCity
      </div>
      <h1 style="font-size: 2rem; margin-bottom: 12px;">Maintenance Mode</h1>
      <p style="color: var(--text-muted); max-width: 420px; margin: 0 auto 24px; font-size: 1.05rem; line-height: 1.5;">
        <%= message || 'HyperCity is undergoing scheduled maintenance. We will be back online shortly.' %>
      </p>
      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <button onclick="location.reload()" class="btn btn-primary">Retry</button>
        <a href="/auth/logout" class="btn btn-ghost" onclick="event.preventDefault(); document.cookie.split(';').forEach(c => document.cookie = c.trim().split('=')[0]+'=;expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/'); window.location.href='/';">Go to Login</a>
        <a href="/" class="btn btn-ghost">Go Home</a>
      </div>
    </div>
  </div>
</body>
</html>