<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Warboard' }) %>
  <style>
    /* ============================================================
       WARBOARD – MAIN STYLES (all existing styles)
       ============================================================ */
    .warboard-container { width: 100%; max-width: 600px; margin: 0 auto; }
    .clan-map-wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 456 / 1013;
      background-image: url('/images/clan/map_background.png');
      background-size: 100% 100%;
      background-repeat: no-repeat;
      user-select: none;
      border-radius: var(--radius);
      overflow: visible !important;
      box-shadow: 0 8px 30px rgba(0,0,0,0.4);
      -webkit-tap-highlight-color: transparent;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease;
      will-change: opacity;
    }
    .clan-map-wrapper.ready { opacity: 1; visibility: visible; }
    .clan-map-wrapper .building {
      position: absolute;
      cursor: pointer;
      transition: transform 0.2s ease, filter 0.2s ease;
      transform-origin: center bottom;
      outline: none;
      -webkit-tap-highlight-color: transparent;
      will-change: transform;
    }
    .building-image {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      pointer-events: none;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.4));
      -webkit-tap-highlight-color: transparent;
      user-select: none;
      -webkit-user-drag: none;
    }
    .building-name-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      text-align: center;
      pointer-events: none;
      padding: 4px 0;
      box-sizing: border-box;
      z-index: 2;
    }
    .building-name-overlay .name-pill {
      display: inline-block;
      background: rgba(0,0,0,0.55);
      padding: 2px 10px;
      border-radius: 12px;
      font-family: var(--font-body), sans-serif;
      font-weight: 700;
      color: #fff;
      font-size: clamp(0.5rem, 1.2vw, 0.85rem);
      letter-spacing: 0.03em;
      white-space: nowrap;
      text-overflow: ellipsis;
      overflow: hidden;
      max-width: 90%;
      box-shadow: 0 1px 4px rgba(0,0,0,0.3);
      text-shadow: 0 1px 2px rgba(0,0,0,0.6);
      backdrop-filter: blur(1px);
    }
    .building-shields {
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 3px;
      width: max-content;
      max-width: 100%;
      pointer-events: none;
      padding: 2px 0;
      box-sizing: border-box;
      z-index: 10;
      will-change: transform;
    }
    .shield-icon {
      width: 18px;
      height: 18px;
      object-fit: contain;
      flex-shrink: 0;
      display: block;
      image-rendering: pixelated;
      transition: opacity 0.15s ease;
      will-change: opacity;
    }
    .clan-map-wrapper .building:hover { transform: scale(1.05); z-index: 20; }
    .clan-map-wrapper .building:active { transform: scale(0.97); }
    @media (max-width: 480px) {
      .building-name-overlay .name-pill { font-size: clamp(0.4rem, 1.8vw, 0.65rem); padding: 1px 6px; border-radius: 8px; }
      .shield-icon { width: 15px; height: 15px; }
      .building-shields { gap: 2px; }
    }
    @media (max-width: 360px) {
      .building-name-overlay .name-pill { font-size: 0.4rem; padding: 1px 4px; }
      .shield-icon { width: 12px; height: 12px; }
      .building-shields { gap: 1.5px; }
    }

    /* ---- Modals ---- */
    .modal-overlay, .selector-overlay, .might-modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      will-change: opacity;
      transition: opacity 0.25s ease;
      opacity: 0;
    }
    .modal-overlay.open, .selector-overlay.open, .might-modal-overlay.open {
      display: flex;
      opacity: 1;
    }
    .modal-overlay.closing, .selector-overlay.closing, .might-modal-overlay.closing {
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }
    .modal-box, .selector-box, .might-modal-box {
      background: var(--bg-2);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      max-width: 750px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,0.6);
      position: relative;
      font-family: var(--font-body), sans-serif;
      color: var(--text-primary);
      scrollbar-width: thin;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      transform: scale(0.95);
      transition: transform 0.25s ease, opacity 0.25s ease;
      opacity: 0;
      will-change: transform, opacity;
    }
    .modal-overlay.open .modal-box,
    .selector-overlay.open .selector-box,
    .might-modal-overlay.open .might-modal-box {
      transform: scale(1);
      opacity: 1;
    }
    .selector-box { max-width: 500px; display: flex; flex-direction: column; max-height: calc(100vh - 60px); }
    .selector-header { position: sticky; top: 0; z-index: 20; background: var(--bg-2); padding: 16px 20px 8px; border-bottom: 1px solid var(--glass-border); }
    .selector-search-wrap { position: sticky; top: 62px; z-index: 19; background: var(--bg-2); padding: 0 20px 12px; border-bottom: 1px solid var(--glass-border); }
    .selector-search { width: 100%; padding: 10px 14px; border: 1px solid var(--glass-border); border-radius: 10px; font-size: 0.95rem; background: var(--glass); color: var(--text-primary); box-sizing: border-box; }
    .selector-add-external { padding: 8px 20px 12px; border-bottom: 1px solid var(--glass-border); display: flex; flex-direction: column; gap: 6px; }
    .selector-list-wrap { flex: 1; overflow-y: auto; padding: 0 20px 20px; -webkit-overflow-scrolling: touch; }
    .selector-player { display: flex; align-items: center; gap: 12px; padding: 10px; border-radius: 10px; cursor: pointer; transition: background 0.15s; border: 1px solid transparent; color: var(--text-primary); flex-wrap: wrap; }
    .selector-player:hover { background: var(--glass); border-color: var(--glass-border); }
    .selector-player img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; background: var(--glass-strong); }
    .selector-player .info { flex: 1; min-width: 100px; }
    .group-header { font-weight: 600; color: var(--text-muted); font-size: 0.8rem; padding: 8px 0 4px; border-top: 1px solid var(--glass-border); margin-top: 4px; }
    .selector-player .move-btn { background: var(--accent-blurple); color: #fff; border: none; padding: 4px 12px; border-radius: 8px; font-size: 0.7rem; cursor: pointer; transition: background 0.2s; }
    .selector-player .move-btn:hover { background: var(--accent-purple); }
    .selector-player .assigned-info {
      font-size: 0.75rem;
      color: var(--accent-amber);
      font-weight: 500;
      margin-top: 2px;
      width: 100%;
      font-style: italic;
    }
    .selector-player .assigned-info i { margin-right: 4px; }

    /* ---- Building Modal ---- */
    .modal-header {
      background: linear-gradient(145deg, #2a4b7a, #1a3a5c);
      padding: 16px 20px;
      border-radius: var(--radius) var(--radius) 0 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 3px solid #8aacd4;
      position: relative;
    }
    .modal-header::after {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      right: 0;
      height: 8px;
      background: linear-gradient(to right, #8aacd4, #4a7a9c, #8aacd4);
      border-radius: 0 0 50% 50%;
    }
    .modal-header .left { display: flex; align-items: center; gap: 10px; }
    .modal-header h2 { color: #f0e6d8; font-weight: 700; font-size: 1.6rem; margin: 0; letter-spacing: 0.03em; text-shadow: 0 2px 4px rgba(0,0,0,0.3); }
    .modal-header .close-btn {
      background: rgba(255,255,255,0.1) !important;
      border: 1px solid var(--glass-border) !important;
      color: var(--text-primary) !important;
      width: 34px !important;
      height: 34px !important;
      border-radius: 50% !important;
      font-size: 1.3rem !important;
      cursor: pointer !important;
      transition: background 0.2s, transform 0.15s !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 0 !important;
      line-height: 1 !important;
    }
    .modal-header .close-btn:hover {
      background: rgba(255,50,50,0.3) !important;
      color: #fff !important;
      transform: scale(1.05) !important;
    }
    .modal-body { padding: 20px 24px 30px; }
    .modal-box .btn,
    .selector-box .btn,
    .might-modal-box .btn {
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 8px 18px !important;
      border-radius: 10px !important;
      font-weight: 600 !important;
      font-size: 0.9rem !important;
      cursor: pointer !important;
      border: 1px solid var(--glass-border) !important;
      background: var(--glass) !important;
      color: var(--text-primary) !important;
      transition: background 0.15s, transform 0.1s !important;
      font-family: var(--font-body) !important;
      text-decoration: none !important;
    }
    .modal-box .btn:hover,
    .selector-box .btn:hover,
    .might-modal-box .btn:hover {
      background: var(--glass-strong) !important;
    }
    .modal-box .btn-primary,
    .selector-box .btn-primary,
    .might-modal-box .btn-primary {
      background: linear-gradient(135deg, var(--accent-blurple), var(--accent-purple)) !important;
      border: none !important;
      color: #fff !important;
    }
    .modal-box .btn-primary:hover,
    .selector-box .btn-primary:hover,
    .might-modal-box .btn-primary:hover {
      box-shadow: 0 4px 16px rgba(88,101,242,0.4) !important;
    }
    .modal-box .btn-danger,
    .selector-box .btn-danger,
    .might-modal-box .btn-danger {
      background: var(--danger) !important;
      border: none !important;
      color: #fff !important;
    }
    .modal-box .btn-danger:hover,
    .selector-box .btn-danger:hover,
    .might-modal-box .btn-danger:hover {
      background: #c0392b !important;
    }
    .modal-box .btn-ghost,
    .selector-box .btn-ghost,
    .might-modal-box .btn-ghost {
      background: var(--glass) !important;
      border: 1px solid var(--glass-border) !important;
      color: var(--text-primary) !important;
    }
    .modal-box .btn-ghost:hover,
    .selector-box .btn-ghost:hover,
    .might-modal-box .btn-ghost:hover {
      background: var(--glass-strong) !important;
    }
    .building-stats {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--glass);
      border-radius: 14px;
      padding: 12px 18px;
      margin-bottom: 20px;
      border: 1px solid var(--glass-border);
    }
    .capacity-badge { display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 1.1rem; }
    .capacity-badge i { color: var(--accent-amber); font-size: 1.2rem; }
    .shield-status { display: flex; gap: 4px; align-items: center; }
    .shield-status img { width: 24px; height: 24px; object-fit: contain; filter: drop-shadow(0 1px 2px rgba(0,0,0,0.2)); }
    .garrison-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
      margin-top: 6px;
    }
    .garrison-slot {
      background: var(--glass);
      border-radius: 14px;
      border: 1px solid var(--glass-border);
      padding: 12px;
      min-height: 100px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      position: relative;
      transition: all 0.2s ease;
      will-change: transform, opacity;
    }
    .garrison-slot.empty {
      border: 2px dashed var(--glass-border);
      background: rgba(255,255,255,0.02);
      cursor: pointer;
      justify-content: center;
    }
    .garrison-slot.empty:hover { background: var(--glass-strong); border-color: var(--accent-cyan); }
    .garrison-slot .empty-content { display: flex; flex-direction: column; align-items: center; gap: 4px; color: var(--text-muted); font-size: 0.8rem; }
    .garrison-slot .empty-content i { font-size: 2rem; color: var(--text-muted); }
    .garrison-slot .slot-shield { position: absolute; top: 4px; right: 4px; width: 20px; height: 20px; object-fit: contain; }
    .garrison-slot .player-avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; border: 2px solid var(--glass-border); margin-bottom: 4px; }
    .garrison-slot .player-name { font-weight: 600; font-size: 0.9rem; text-align: center; margin: 2px 0; }
    .garrison-slot .player-might { font-size: 0.75rem; color: var(--text-muted); text-align: center; }
    .hero-gallery { display: flex; gap: 4px; flex-wrap: wrap; justify-content: center; margin: 4px 0; }
    .hero-gallery .hero-thumb { width: 36px; height: 36px; border-radius: 6px; object-fit: cover; border: 1px solid var(--glass-border); cursor: pointer; transition: transform 0.15s; background: var(--glass-strong); will-change: transform; }
    .hero-gallery .hero-thumb:hover { transform: scale(1.1); }
    .slot-actions { display: flex; gap: 4px; margin-top: 6px; flex-wrap: wrap; justify-content: center; }
    .slot-actions button { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 8px; padding: 2px 8px; font-size: 0.7rem; cursor: pointer; transition: background 0.15s; color: var(--text-primary); }
    .slot-actions button:hover { background: var(--glass-strong); }
    .slot-actions .remove-btn:hover { background: var(--danger); color: #fff; border-color: var(--danger); }
    .section-title { font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin: 18px 0 10px; border-bottom: 1px solid var(--glass-border); padding-bottom: 6px; }

    /* ---- Export preview ---- */
    .export-preview {
      background: var(--bg-2);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      padding: 20px;
      max-height: 600px;
      overflow-y: auto;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--text-primary);
      line-height: 1.5;
      white-space: pre-wrap;
      -webkit-overflow-scrolling: touch;
    }
    .export-preview .building-card { background: var(--glass); border-radius: var(--radius-sm); border-left: 4px solid var(--accent-cyan); padding: 12px 16px; margin-bottom: 12px; transition: transform 0.15s, box-shadow 0.15s; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .export-preview .building-card:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.15); }
    .export-preview .building-header { font-weight: 700; font-size: 1rem; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
    .export-preview .building-header .capacity-badge { font-weight: 400; color: var(--text-muted); font-size: 0.8rem; }
    .export-preview .player-line { display: flex; align-items: center; gap: 6px; padding: 2px 0; }
    .export-preview .player-name { font-weight: 600; color: var(--text-primary); }
    .export-preview .player-might { color: var(--accent-amber); font-size: 0.8rem; }
    .export-preview .player-external { font-size: 0.7rem; color: var(--text-muted); margin-left: 4px; }
    .building-card.citadel { border-left-color: #4a90d9; }
    .building-card.main_gate { border-left-color: #2ecc71; }
    .building-card.docks { border-left-color: #e67e22; }
    .building-card.boathouse { border-left-color: #e74c3c; }
    .building-card.tower_of_elements { border-left-color: #9b59b6; }
    .building-card.tower_of_foresight { border-left-color: #f1c40f; }
    .building-card.central_bridge { border-left-color: #1abc9c; }
    .building-card.western_bridge { border-left-color: #d35400; }
    .building-card.eastern_bridge { border-left-color: #e91e63; }
    .building-card.laboratory { border-left-color: #bdc3c7; }
    .building-card.scriptorium { border-left-color: #2ecc71; }
    .export-controls { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; margin-bottom: 16px; }
    .export-controls .control-group { display: flex; align-items: center; gap: 8px; }
    .export-controls input[type="date"] { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 8px; padding: 6px 12px; color: var(--text-primary); }
    .export-controls label { display: flex; align-items: center; gap: 6px; cursor: pointer; }
    .export-controls .btn-group { display: flex; gap: 8px; margin-left: auto; }
    @media (max-width: 768px) { .export-controls { flex-direction: column; align-items: stretch; } .export-controls .btn-group { margin-left: 0; } }

    /* ---- Scroll improvements ---- */
    .page-content, .main-wrap, .app-shell { overscroll-behavior: contain; -webkit-overflow-scrolling: touch; }
    .container { scroll-behavior: smooth; }
    .mt-24 { margin-top: 24px; }
    .text-muted { color: var(--text-muted); }
    .btn-sm { padding: 4px 10px; font-size: 0.8rem; }

    /* ---- TOOLBAR ---- */
    .warboard-toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 16px;
      padding: 12px 16px;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      align-items: center;
    }
    .warboard-toolbar .btn { padding: 6px 14px; font-size: 0.85rem; }
    .warboard-toolbar .spacer { flex: 1; }

    /* ============================================================
       FULL-SCREEN IMAGE VIEWER
       ============================================================ */
    #imageViewer {
      position: fixed !important;
      inset: 0 !important;
      z-index: 99999 !important;
      background: rgba(0, 0, 0, 0.92) !important;
      backdrop-filter: blur(12px) !important;
      display: none !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 20px !important;
      box-sizing: border-box !important;
      opacity: 0;
      transition: opacity 0.3s ease;
      touch-action: none;
      user-select: none;
    }
    #imageViewer.open {
      display: flex !important;
      opacity: 1 !important;
    }
    #imageViewer.closing {
      opacity: 0 !important;
      pointer-events: none !important;
      transition: opacity 0.2s ease;
    }
    #imageViewer .viewer-modal {
      position: relative !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
      max-width: 95vw !important;
      max-height: 95vh !important;
      width: auto !important;
      height: auto !important;
      background: transparent !important;
      border-radius: 8px !important;
      overflow: visible !important;
    }
    #imageViewer .viewer-img-wrap {
      position: relative !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      width: auto !important;
      height: auto !important;
      max-width: 90vw !important;
      max-height: 80vh !important;
      touch-action: none !important;
      will-change: transform, opacity !important;
      flex-shrink: 1 !important;
      background: transparent !important;
    }
    #imageViewer .viewer-img {
      max-width: 100% !important;
      max-height: 100% !important;
      object-fit: contain !important;
      will-change: transform !important;
      transition: transform 0.1s ease !important;
      touch-action: none !important;
      cursor: grab !important;
      display: block !important;
      border-radius: 4px !important;
      box-shadow: 0 8px 40px rgba(0,0,0,0.6) !important;
    }
    #imageViewer .viewer-img.dragging { cursor: grabbing !important; }
    #imageViewer .viewer-close {
      position: absolute !important;
      top: 12px !important;
      right: 12px !important;
      background: rgba(0,0,0,0.6) !important;
      border: 1px solid rgba(255,255,255,0.15) !important;
      color: #fff !important;
      font-size: 1.8rem !important;
      width: 44px !important;
      height: 44px !important;
      border-radius: 50% !important;
      cursor: pointer !important;
      z-index: 20 !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      transition: background 0.2s, transform 0.15s !important;
      backdrop-filter: blur(4px) !important;
      line-height: 1 !important;
      padding: 0 !important;
      border: none !important;
    }
    #imageViewer .viewer-close:hover {
      background: rgba(255, 50, 50, 0.7) !important;
      transform: scale(1.05) !important;
    }
    #imageViewer .viewer-nav {
      position: absolute !important;
      top: 50% !important;
      transform: translateY(-50%) !important;
      background: rgba(0,0,0,0.5) !important;
      border: 1px solid rgba(255,255,255,0.1) !important;
      color: #fff !important;
      font-size: 2.2rem !important;
      width: 48px !important;
      height: 48px !important;
      border-radius: 50% !important;
      cursor: pointer !important;
      z-index: 15 !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      transition: background 0.2s, transform 0.15s !important;
      backdrop-filter: blur(4px) !important;
      line-height: 1 !important;
      padding: 0 !important;
      border: none !important;
    }
    #imageViewer .viewer-nav:hover {
      background: rgba(255,255,255,0.2) !important;
      transform: translateY(-50%) scale(1.05) !important;
    }
    #imageViewer .viewer-nav.prev { left: 10px !important; right: auto !important; }
    #imageViewer .viewer-nav.next { right: 10px !important; left: auto !important; }
    #imageViewer .viewer-loading,
    #imageViewer .viewer-error {
      position: absolute !important;
      top: 50% !important;
      left: 50% !important;
      transform: translate(-50%, -50%) !important;
      z-index: 10 !important;
      color: #fff !important;
      text-align: center !important;
      font-size: 1.2rem !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      gap: 12px !important;
      pointer-events: none !important;
    }
    #imageViewer .viewer-loading .spinner {
      width: 40px !important;
      height: 40px !important;
      border: 4px solid rgba(255,255,255,0.2) !important;
      border-top: 4px solid #fff !important;
      border-radius: 50% !important;
      animation: spin 1s linear infinite !important;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    #imageViewer .viewer-error button {
      pointer-events: auto !important;
      background: var(--accent-cyan) !important;
      border: none !important;
      color: #fff !important;
      padding: 8px 20px !important;
      border-radius: 8px !important;
      cursor: pointer !important;
      margin-top: 10px !important;
      font-size: 1rem !important;
    }
    #imageViewer .viewer-controls {
      display: flex !important;
      gap: 12px !important;
      align-items: center !important;
      background: rgba(0,0,0,0.5) !important;
      backdrop-filter: blur(10px) !important;
      padding: 10px 18px !important;
      border-radius: 40px !important;
      border: 1px solid rgba(255,255,255,0.1) !important;
      margin-top: 16px !important;
      flex-shrink: 0 !important;
      user-select: none !important;
      z-index: 5 !important;
    }
    #imageViewer .viewer-controls button {
      background: transparent !important;
      border: none !important;
      color: #fff !important;
      font-size: 1.2rem !important;
      width: 36px !important;
      height: 36px !important;
      border-radius: 50% !important;
      cursor: pointer !important;
      transition: background 0.2s !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 0 !important;
    }
    #imageViewer .viewer-controls button:hover {
      background: rgba(255,255,255,0.15) !important;
    }
    #imageViewer .viewer-controls .counter {
      color: #fff !important;
      font-size: 0.9rem !important;
      padding: 0 8px !important;
      min-width: 70px !important;
      text-align: center !important;
    }
    @media (max-width: 600px) {
      #imageViewer .viewer-modal { max-width: 98vw !important; max-height: 98vh !important; }
      #imageViewer .viewer-img-wrap { max-width: 95vw !important; max-height: 70vh !important; }
      #imageViewer .viewer-close { top: 8px !important; right: 8px !important; width: 36px !important; height: 36px !important; font-size: 1.4rem !important; }
      #imageViewer .viewer-nav { width: 36px !important; height: 36px !important; font-size: 1.6rem !important; }
      #imageViewer .viewer-nav.prev { left: 6px !important; }
      #imageViewer .viewer-nav.next { right: 6px !important; }
      #imageViewer .viewer-controls { padding: 8px 12px !important; gap: 8px !important; margin-top: 12px !important; }
      #imageViewer .viewer-controls button { width: 30px !important; height: 30px !important; font-size: 1rem !important; }
      #imageViewer .viewer-controls .counter { font-size: 0.8rem !important; min-width: 50px !important; }
    }
    #imageViewer .viewer-close,
    #imageViewer .viewer-nav,
    #imageViewer .viewer-controls button {
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
    }
    #imageViewer .viewer-close,
    #imageViewer .viewer-nav { position: absolute !important; }
    #imageViewer .viewer-close {
      right: 12px !important;
      top: 12px !important;
      left: auto !important;
      bottom: auto !important;
    }
    #imageViewer .viewer-nav.prev {
      left: 10px !important;
      right: auto !important;
      top: 50% !important;
      bottom: auto !important;
      transform: translateY(-50%) !important;
    }
    #imageViewer .viewer-nav.next {
      right: 10px !important;
      left: auto !important;
      top: 50% !important;
      bottom: auto !important;
      transform: translateY(-50%) !important;
    }

    /* ---- Toast z-index ---- */
    .toast-container { z-index: 999999 !important; }

    /* ---- Cross button for selector modals ---- */
    .selector-box .close-btn,
    .modal-header .close-btn {
      background: rgba(255,255,255,0.1) !important;
      border: 1px solid var(--glass-border) !important;
      color: var(--text-primary) !important;
      width: 34px !important;
      height: 34px !important;
      border-radius: 50% !important;
      font-size: 1.3rem !important;
      cursor: pointer !important;
      transition: background 0.2s, transform 0.15s !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      padding: 0 !important;
      line-height: 1 !important;
    }
    .selector-box .close-btn:hover,
    .modal-header .close-btn:hover {
      background: rgba(255,50,50,0.3) !important;
      color: #fff !important;
      transform: scale(1.05) !important;
    }

    .btn-loading {
      pointer-events: none !important;
      opacity: 0.8;
    }
    .btn-loading .spinner-dots::after {
      content: '';
      animation: dots 1.2s steps(4, end) infinite;
    }
    @keyframes dots {
      0% { content: ''; }
      25% { content: '.'; }
      50% { content: '..'; }
      75% { content: '...'; }
      100% { content: ''; }
    }
    .btn-loading .spinner-border-sm {
      display: inline-block !important;
      width: 1rem;
      height: 1rem;
      border: 0.15rem solid currentColor;
      border-right-color: transparent;
      border-radius: 50%;
      animation: spinner-border 0.75s linear infinite;
      vertical-align: middle;
      margin-right: 6px;
    }
    @keyframes spinner-border { to { transform: rotate(360deg); } }

    .player-card-fade-out { animation: fadeOut 0.3s ease forwards; }
    .player-card-fade-in { animation: fadeIn 0.3s ease forwards; }
    @keyframes fadeOut {
      from { opacity: 1; transform: scale(1); }
      to { opacity: 0; transform: scale(0.95); }
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
    .building-glow { animation: glowPulse 0.5s ease 2; }
    @keyframes glowPulse {
      0% { box-shadow: 0 0 0 0 rgba(88,101,242,0.4); }
      50% { box-shadow: 0 0 20px 10px rgba(88,101,242,0.6); }
      100% { box-shadow: 0 0 0 0 rgba(88,101,242,0.4); }
    }
    .modal-loading-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(4px);
      border-radius: var(--radius);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 50;
      color: #fff;
      font-size: 1rem;
      gap: 12px;
    }
    .modal-loading-overlay .spinner {
      width: 40px;
      height: 40px;
      border: 4px solid rgba(255,255,255,0.2);
      border-top: 4px solid #fff;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    .modal-loading-overlay.hidden { display: none; }

    /* ============================================================
       DISCORD DM SECTION – Styles (with spacing fixes)
       ============================================================ */
    .dm-card {
      margin-top: 24px;
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius);
      padding: 20px;
    }
    .dm-tabs {
      display: flex;
      gap: 4px;
      border-bottom: 1px solid var(--glass-border);
      margin-bottom: 16px;
    }
    .dm-tab {
      background: transparent;
      border: none;
      border-bottom: 2px solid transparent;
      color: var(--text-muted);
      font-family: var(--font-body), sans-serif;
      font-weight: 600;
      font-size: 0.9rem;
      padding: 8px 16px;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
    }
    .dm-tab:hover { color: var(--text-primary); }
    .dm-tab.active {
      color: var(--accent-cyan);
      border-bottom-color: var(--accent-cyan);
    }
    .dm-tab-content { display: block; }
    .dm-tab-content.dm-hidden { display: none; }

    .dm-toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      margin-bottom: 12px;
    }
    .dm-template-select {
      padding: 6px 10px;
      border: 1px solid var(--glass-border);
      border-radius: 8px;
      background: var(--bg-2);
      color: var(--text-primary);
      font-size: 0.85rem;
      min-width: 160px;
      font-family: var(--font-body), sans-serif;
    }
    .dm-last-edited {
      margin-left: auto;
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .dm-editor-wrap { position: relative; margin-bottom: 10px; }
    .dm-message-textarea {
      width: 100%;
      min-height: 140px;
      background: var(--bg-2);
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      color: var(--text-primary);
      padding: 12px;
      font-family: var(--font-body), sans-serif;
      font-size: 0.9rem;
      resize: vertical;
      box-sizing: border-box;
      transition: border-color 0.2s;
    }
    .dm-message-textarea:focus { border-color: var(--accent-cyan); outline: none; }

    .dm-char-counter,
    .char-counter {
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .dm-editor-wrap .dm-char-counter {
      position: absolute;
      bottom: 8px;
      right: 12px;
      background: var(--bg-2);
      padding: 1px 6px;
      border-radius: 6px;
    }
    .dm-char-counter.warning, .char-counter.warning { color: var(--accent-amber); }
    .dm-char-counter.danger, .char-counter.danger { color: var(--danger); }

    .dm-variables-group {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin: 10px 0 14px;
      padding: 10px 12px;
      background: var(--bg-2);
      border: 1px solid var(--glass-border);
      border-radius: 10px;
    }
    .var-group {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 6px;
    }
    .var-group-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      margin-right: 4px;
    }
    .var-btn {
      background: var(--glass-strong);
      border: 1px solid var(--glass-border);
      border-radius: 6px;
      padding: 2px 10px;
      font-size: 0.75rem;
      cursor: pointer;
      font-family: var(--font-mono), monospace;
      color: var(--text-primary);
      transition: background 0.15s, color 0.15s;
    }
    .var-btn:hover { background: var(--accent-blurple); color: #fff; }

    /* FIX: Reduce margin below send mode */
    .dm-send-mode {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 6px;   /* was 14px */
      font-size: 0.9rem;
    }
    .dm-send-mode label {
      display: flex;
      align-items: center;
      gap: 6px;
      cursor: pointer;
      color: var(--text-primary);
    }
    .dm-send-mode input[type="radio"] { accent-color: var(--accent-blurple); }

    .dm-player-selector {
      display: flex;
      gap: 14px;
      margin-bottom: 6px;   /* was 14px */
      flex-wrap: wrap;
    }
    .dm-player-search-wrap {
      position: relative;
      flex: 1 1 260px;
      min-width: 220px;
      display: flex;
      align-items: center;
    }
    .dm-player-search-wrap i {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      line-height: 1;
      color: var(--text-muted);
      font-size: 0.85rem;
    }
    .dm-player-search {
      width: 100%;
      padding: 8px 12px 8px 32px;
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      background: var(--bg-2);
      color: var(--text-primary);
      font-size: 0.9rem;
      box-sizing: border-box;
      height: 42px;
    }
    .dm-player-search:focus { border-color: var(--accent-cyan); outline: none; }

    .dm-player-list {
      flex: 1 1 260px;
      min-width: 220px;
      max-height: 260px;
      overflow-y: auto;
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      background: var(--bg-2);
      margin-bottom: 6px;   /* was 14px, now reduced */
    }
    .player-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      cursor: pointer;
      border-bottom: 1px solid var(--glass-border);
      transition: background 0.15s;
    }
    .player-item:last-child { border-bottom: none; }
    .player-item:hover { background: var(--glass); }
    .player-item.selected { background: var(--glass-strong); }
    .player-item img {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .player-item .pinfo { min-width: 0; }
    .player-item .pname {
      font-weight: 600;
      font-size: 0.88rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .player-item .pdetails {
      font-size: 0.75rem;
      color: var(--text-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .dm-list-empty {
      padding: 16px 12px 4px;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.85rem;
    }

    .dm-player-info { flex: 1 1 220px; min-width: 200px; }
    .dm-player-info-card {
      display: none;
      gap: 10px;
      align-items: center;
      padding: 12px;
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      background: var(--bg-2);
    }
    .dm-player-info-card.visible { display: flex; }
    .player-avatar-wrapper img { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
    .player-details { min-width: 0; }
    .player-details .player-name { font-weight: 700; font-size: 0.95rem; }
    .player-details .player-discord,
    .player-details .player-building,
    .player-details .player-might {
      font-size: 0.78rem;
      color: var(--text-muted);
    }
    .player-details .player-status { font-size: 0.8rem; font-weight: 600; margin-top: 2px; }

    /* FIX: Reduce margin below building selector */
    .dm-building-selector {
      margin-bottom: 6px;   /* was 14px */
    }
    .dm-building-selector label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-muted);
      margin-bottom: 6px;
    }
    .dm-building-dropdown {
      width: 100%;
      padding: 8px 12px;
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      background: var(--bg-2);
      color: var(--text-primary);
      font-size: 0.9rem;
      box-sizing: border-box;
      margin-bottom: 6px;   /* was 10px */
    }
    .dm-building-players { border: 1px solid var(--glass-border); border-radius: 10px; background: var(--bg-2); }
    .dm-building-player-count {
      display: block;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text-muted);
      padding: 8px 12px;
      border-bottom: 1px solid var(--glass-border);
    }
    .dm-building-player-list { max-height: 180px; overflow-y: auto; }
    .player-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-bottom: 1px solid var(--glass-border);
      font-size: 0.85rem;
    }
    .player-row:last-child { border-bottom: none; }
    .player-row img { width: 24px; height: 24px; border-radius: 50%; object-fit: cover; }
    .player-row .pname { font-weight: 600; }
    .player-row .pdetails { color: var(--text-muted); margin-left: auto; font-size: 0.78rem; }

    .dm-preview-wrapper {
      display: none;
      margin-bottom: 14px;
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      overflow: hidden;
    }
    .dm-preview-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      background: var(--glass-strong);
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-muted);
    }
    .dm-preview-recipient { color: var(--accent-cyan); font-weight: 700; }
    .dm-preview-building { margin-left: auto; }
    .dm-preview-bubble { background: var(--bg-2); padding: 14px; }
    .dm-preview-content {
      font-size: 0.9rem;
      line-height: 1.5;
      color: var(--text-primary);
      white-space: pre-wrap;
      word-break: break-word;
    }
    .dm-preview-empty { color: var(--text-muted); font-style: italic; font-size: 0.85rem; }
    .dm-preview-error { color: var(--danger); font-size: 0.85rem; }
    .dm-preview-content .mention {
      background: rgba(88,101,242,0.2);
      color: var(--accent-blurple);
      padding: 0 4px;
      border-radius: 4px;
      font-weight: 600;
    }

    /* FIX: Reduce top margin of actions */
    .dm-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      margin-top: 6px;      /* was 10px */
    }
    .dm-actions .char-counter { margin-left: auto; }

    #dmTestSendBtn {
      background: var(--glass-strong);
      border-color: var(--glass-border);
    }
    #dmTestSendBtn:hover { background: var(--glass); }

    .dm-progress-panel {
      margin-top: 12px;
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-sm);
      padding: 16px;
      background: var(--bg-2);
    }
    .dm-progress-header {
      display: flex;
      justify-content: space-between;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .dm-progress-header #dmProgressETA {
      color: var(--text-muted);
      font-weight: 400;
    }
    .dm-progress-bar-wrap {
      width: 100%;
      height: 8px;
      background: var(--glass);
      border-radius: 4px;
      overflow: hidden;
      margin-bottom: 12px;
    }
    .dm-progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent-blurple), var(--accent-cyan));
      border-radius: 4px;
      transition: width 0.3s ease;
      width: 0%;
    }
    .dm-progress-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
      gap: 6px;
      margin-bottom: 8px;
    }
    .dm-stat-item {
      display: flex;
      flex-direction: column;
      font-size: 0.8rem;
    }
    .dm-stat-item .label { color: var(--text-muted); }
    .dm-stat-item .value { font-weight: 600; font-size: 1rem; }
    .dm-progress-current {
      display: flex;
      gap: 8px;
      font-size: 0.85rem;
      margin-bottom: 8px;
    }
    .dm-progress-current .label { color: var(--text-muted); }
    .dm-progress-current .value { font-weight: 500; }
    .dm-progress-actions { margin-top: 8px; display: flex; gap: 8px; }
    .dm-progress-complete {
      margin-top: 8px;
      border-top: 1px solid var(--glass-border);
      padding-top: 12px;
    }
    .dm-progress-complete .dm-progress-stats {
      grid-template-columns: repeat(4, 1fr);
    }

    .dm-history-toolbar {
      display: flex;
      gap: 8px;
      margin-bottom: 12px;
    }
    .dm-history-search {
      flex: 1;
      padding: 8px 12px;
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      background: var(--bg-2);
      color: var(--text-primary);
      font-size: 0.9rem;
    }
    .dm-history-list {
      border: 1px solid var(--glass-border);
      border-radius: 10px;
      background: var(--bg-2);
      overflow: hidden;
    }
    .dm-history-empty { padding: 20px; text-align: center; color: var(--text-muted); font-size: 0.9rem; }
    .dm-history-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 10px 14px;
      border-bottom: 1px solid var(--glass-border);
    }
    .dm-history-item:last-child { border-bottom: none; }
    .dm-history-item .h-title { font-weight: 600; font-size: 0.9rem; }
    .dm-history-item .h-details { font-size: 0.78rem; color: var(--text-muted); }
    .dm-history-item .h-right { text-align: right; }
    .dm-history-item .h-stats { font-size: 0.85rem; font-weight: 600; }
    .dm-history-item .h-stats .success { color: var(--success); }
    .dm-history-item .h-stats .failed { color: var(--danger); }
    .dm-history-item .h-time { font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; }
    .dm-history-pagination {
      display: flex;
      gap: 4px;
      justify-content: center;
      margin-top: 12px;
      flex-wrap: wrap;
    }
    .page-btn {
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 0.8rem;
      color: var(--text-primary);
      cursor: pointer;
      transition: background 0.15s;
    }
    .page-btn:hover { background: var(--glass-strong); }
    .page-btn.active { background: var(--accent-blurple); color: #fff; border-color: var(--accent-blurple); }
    .page-ellipsis { padding: 4px 4px; color: var(--text-muted); }
    @media (max-width: 640px) {
      .dm-player-selector { flex-direction: column; }
      .dm-toolbar { gap: 6px; }
      .dm-last-edited { margin-left: 0; width: 100%; }
    }
  </style>
</head>
<body>
  <%- include('partials/loading-screen') %>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'warboard' }) %>
    <div class="main-wrap">
      <%- include('partials/topbar') %>
      <main class="page-content">
        <div class="container">
          <h1 style="margin-bottom:8px;"><%= t['warboard.title'] || 'Warboard' %></h1>
          <p class="text-muted" style="margin-bottom:24px;"><%= t['warboard.subtitle'] || 'Clan map and strategic overview' %></p>

          <!-- TOOLBAR -->
          <div class="warboard-toolbar">
            <span class="spacer"></span>
            <button class="btn btn-primary" id="warboardLogsBtn"><i class="bi bi-clock-history"></i> Warboard Logs</button>
          </div>

          <!-- MAP -->
          <div class="glass card warboard-container" style="padding:12px;">
            <div class="clan-map-wrapper" id="clanMap"></div>
          </div>

          <!-- DISCORD DM SECTION -->
          <div class="dm-card">
            <%- include('warboard/warboard_dm') %>
          </div>

          <!-- EXPORT -->
          <div class="glass card mt-24" style="padding:20px;">
            <h3 style="margin-bottom:8px;">Discord Warboard Export</h3>
            <p class="text-muted" style="margin-bottom:16px; font-size:0.9rem;">Live preview of the Discord message. Copy the formatted export to your clipboard.</p>
            <div class="export-controls">
              <div class="control-group">
